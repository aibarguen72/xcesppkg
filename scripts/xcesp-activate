#!/bin/bash
# xcesp-activate — sync /var/xcesp/mainsw to active locations
#
# Called by systemd ExecStartPre=+ (runs as root) before starting xcespwdog.
# If /var/xcesp/mainsw exists and contains a VERSION file, its contents are
# synced to the active locations (/usr/bin, /var/xcesp/schema, /var/xcesp/rules)
# and xcesppy in the venv is updated.  Configuration files are never touched.
#
# Also callable manually:  sudo xcesp-activate

set -euo pipefail

XCESP_BASE=/var/xcesp
MAINSW=$XCESP_BASE/mainsw
BINDIR=/usr/bin
XCESP_USER=xcesp
XCESP_GROUP=xcesp

log() { echo "xcesp-activate: $*" >&2; }

# Nothing to do if mainsw does not exist
if [ ! -d "$MAINSW" ]; then
    log "$MAINSW not found — skipping activation"
    exit 0
fi

if [ ! -f "$MAINSW/VERSION" ]; then
    log "$MAINSW/VERSION missing — skipping activation"
    exit 0
fi

log "activating $(head -1 "$MAINSW/VERSION")"

# ---------------------------------------------------------------------------
# /var/xcesp directory ownership / permissions
# ---------------------------------------------------------------------------
# Keep these in sync with install.sh.  Re-applied on every boot so that a
# CLI upgrade (copy sw → backup-sw → software-install) picks up perms
# tightening / loosening from a newer release without requiring a rerun
# of install.sh.  Specifically: xcesp group needs write on /var/xcesp/,
# mainsw/, and backupsw/ for the swap rename and tarball extraction.
for d in "$XCESP_BASE" "$MAINSW" "$XCESP_BASE/backupsw"; do
    [ -d "$d" ] || continue
    chown "root:$XCESP_GROUP" "$d"
    chmod 2775 "$d"
done

# ---------------------------------------------------------------------------
# Self-update of /usr/bin/xcesp-activate and /usr/bin/xcesp-swap.sh
# ---------------------------------------------------------------------------
# After a CLI swap, the new package's scripts live in mainsw/scripts/.
# Copy them over /usr/bin/ so subsequent service starts run the new
# logic (not the install.sh-vintage version that's still in /usr/bin).
# Copy only when content differs — avoids a needless rewrite on every
# start.
if [ -d "$MAINSW/scripts" ]; then
    for s in xcesp-activate xcesp-swap.sh; do
        src="$MAINSW/scripts/$s"
        dst="$BINDIR/$s"
        [ -f "$src" ] || continue
        if [ ! -f "$dst" ] || ! cmp -s "$src" "$dst"; then
            install -o root -g root -m 0755 "$src" "$dst"
            log "  refreshed $dst"
        fi
    done
    # 0.2.2: xcesp-login lives under /usr/lib/xcesp/ (off PATH).  Refresh
    # it from mainsw/scripts/ via the same content-compare pattern.
    if [ -f "$MAINSW/scripts/xcesp-login" ]; then
        mkdir -p /usr/lib/xcesp
        src="$MAINSW/scripts/xcesp-login"
        dst="/usr/lib/xcesp/xcesp-login"
        if [ ! -f "$dst" ] || ! cmp -s "$src" "$dst"; then
            install -o root -g root -m 0755 "$src" "$dst"
            log "  refreshed $dst"
        fi
    fi
    # 0.2.11: xcesp-tacacs-auth is built into the package at build time
    # and dropped into /usr/lib/xcesp/.  Self-refresh from mainsw/lib/xcesp/
    # so a CLI `software-install` (which only swaps mainsw/backupsw, never
    # re-runs install.sh) still picks up new tool versions.
    if [ -f "$MAINSW/lib/xcesp/xcesp-tacacs-auth" ]; then
        mkdir -p /usr/lib/xcesp
        src="$MAINSW/lib/xcesp/xcesp-tacacs-auth"
        dst="/usr/lib/xcesp/xcesp-tacacs-auth"
        if [ ! -f "$dst" ] || ! cmp -s "$src" "$dst"; then
            install -o root -g root -m 0755 "$src" "$dst"
            log "  refreshed $dst"
        fi
    fi
    # 0.2.16: same self-refresh for the RADIUS auth tool.
    if [ -f "$MAINSW/lib/xcesp/xcesp-radius-auth" ]; then
        mkdir -p /usr/lib/xcesp
        src="$MAINSW/lib/xcesp/xcesp-radius-auth"
        dst="/usr/lib/xcesp/xcesp-radius-auth"
        if [ ! -f "$dst" ] || ! cmp -s "$src" "$dst"; then
            install -o root -g root -m 0755 "$src" "$dst"
            log "  refreshed $dst"
        fi
    fi
fi

# ---------------------------------------------------------------------------
# Runtime directory
# ---------------------------------------------------------------------------
# /run is tmpfs — cleared on reboot. systemd RuntimeDirectory= handles this
# for service starts, but manual invocations need this fallback.
install -d -o "$XCESP_USER" -g "$XCESP_GROUP" -m 0750 /run/xcesp
# DHCP feature runtime subdirs.  PObjs create per-namespace/device children
# lazily; pre-creating the parents here keeps the first-tick mkdir chain
# cheap and gives the operator a stable place to look for the pid/log files.
for d in /run/xcesp/dhcp-client /run/xcesp/dhcp-relay /run/xcesp/dhcp4 /run/xcesp/dhcp6; do
    install -d -o "$XCESP_USER" -g "$XCESP_GROUP" -m 0750 "$d"
done
# Persisted DHCP lease dirs live under /var/lib (survives reboot); install.sh
# created them.  Re-stamp ownership here in case a manual chown drifted them.
for d in /var/lib/xcesp/dhcp-client /var/lib/xcesp/dhcp4 /var/lib/xcesp/dhcp6; do
    if [ -d "$d" ]; then
        chown "$XCESP_USER:$XCESP_GROUP" "$d"
        chmod 0750 "$d"
    fi
done
# /run/netns must be owned by xcesp so xcespproc can create namespace bind-files
# without needing to call mount --make-shared (which requires root even with caps)
install -d -o "$XCESP_USER" -g "$XCESP_GROUP" -m 0755 /run/netns
# xtables lock file: iptables-legacy requires this to exist and be group-writable.
# /run is tmpfs cleared on reboot, so re-create it here on every start.
touch /run/xtables.lock
chown "root:$XCESP_GROUP" /run/xtables.lock
chmod 0664 /run/xtables.lock
# Home directory for xcesp user: needed for scp/sftp known_hosts storage.
# Older installs used --no-create-home; ensure the directory exists here.
install -d -o "$XCESP_USER" -g "$XCESP_GROUP" -m 0750 "/home/$XCESP_USER"
install -d -o "$XCESP_USER" -g "$XCESP_GROUP" -m 0700 "/home/$XCESP_USER/.ssh"

# ---------------------------------------------------------------------------
# Binaries
# ---------------------------------------------------------------------------
if [ -d "$MAINSW/bin" ]; then
    for bin in xcespserver xcespcli xcespproc xcespwdog; do
        src="$MAINSW/bin/$bin"
        [ -f "$src" ] || continue
        install -o root -g root -m 0755 "$src" "$BINDIR/$bin"
        log "  installed $BINDIR/$bin"
    done
    # Re-apply capabilities after binary replacement
    if command -v setcap > /dev/null 2>&1 && [ -f "$BINDIR/xcespproc" ]; then
        setcap cap_net_admin,cap_sys_admin,cap_net_raw,cap_net_bind_service=ep "$BINDIR/xcespproc"
        log "  setcap applied to $BINDIR/xcespproc"
    else
        log "  WARNING: setcap not available — xcespproc may lack required capabilities"
    fi
fi

# ---------------------------------------------------------------------------
# strongSwan / charon: setuid root, NO file capabilities
#
# xcespproc launches a per-namespace charon process for every router that
# carries an `ipsec` block.  We need charon to bind UDP 500 (privileged
# port), and inside the per-ns mount/net namespace charon's socket-default
# plugin must be allowed to register listeners.
#
# Subtle but critical: Ubuntu's strongSwan charon ships **without libcap**
# (verified: `ldd /usr/libexec/ipsec/charon | grep cap` is empty), so its
# CAP_NET_BIND_SERVICE check inside `capabilities_t::keep()` falls through
# to the no-CAPABILITIES fallback:
#
#     if (geteuid() == 0) return TRUE;
#     return FALSE;
#
# When xcespproc (running as xcesp) execs charon with file caps, the
# kernel grants the caps but euid stays non-zero — so strongSwan's check
# returns FALSE and socket-default refuses to register, logging
# "socket-default plugin requires CAP_NET_BIND_SERVICE capability".
# The IKE_SA stays CONNECTING forever, no packets are sent.
#
# Fix: drop file caps and use setuid root on the charon binary.  When
# xcespproc execs it, euid becomes 0 → libcap-less check passes →
# socket-default binds 500/4500 → IKE comes up.  This matches the
# upstream Ubuntu strongswan systemd unit, which runs charon as root.
#
# Probe every candidate path — different distros ship charon under
# different prefixes:
#   /usr/libexec/strongswan/charon    Fedora / RHEL
#   /usr/lib/strongswan/charon        Older layouts
#   /usr/libexec/ipsec/charon         Ubuntu (recent strongswan-charon)
#   /usr/lib/ipsec/charon             Ubuntu (older strongswan-charon)
#   /usr/local/libexec/strongswan/charon  manual / from-source installs
# ---------------------------------------------------------------------------
for charon_bin in /usr/libexec/strongswan/charon \
                  /usr/lib/strongswan/charon \
                  /usr/libexec/ipsec/charon \
                  /usr/lib/ipsec/charon \
                  /usr/local/libexec/strongswan/charon; do
    [ -f "$charon_bin" ] || continue
    # Strip any leftover file caps from prior xcesppkg installs (<=0.1.71).
    command -v setcap > /dev/null 2>&1 && setcap -r "$charon_bin" 2>/dev/null || true
    chmod u+s "$charon_bin"
    log "  setuid root applied to $charon_bin (file caps removed)"
done

# NOTE: 0.1.69 wrote a per-namespace charon bootstrap at
# /var/xcesp/strongswan.conf, but that approach hit two distro
# inconsistencies (Ubuntu's strongSwan fatals on a glob `include`
# with zero matches, and the *.conf dirs that exist differ across
# Fedora vs Debian/Ubuntu).  xcespproc 0.0.158+ now writes a fully
# self-contained per-namespace charon-ns.conf and probes the
# candidate plugin-enabler dirs at write time, emitting `include`
# only for dirs that actually exist.  No host-file bootstrap needed
# any more.  If an older bootstrap is sitting in /var/xcesp/, remove
# it so a future xcespproc that still tries to include it doesn't
# read stale settings.
rm -f /var/xcesp/strongswan.conf 2>/dev/null || true

# ---------------------------------------------------------------------------
# strongSwan plugin .conf files (Ubuntu DAC fix)
#
# Ubuntu's strongswan-charon package ships /etc/strongswan.d/charon/*.conf
# as mode 0600 root:root.  Our per-namespace charon runs as user `xcesp`
# (not root) with file capabilities, and on Ubuntu's strongSwan an
# include glob that finds files it cannot read is FATAL during init,
# before syslog is opened — charon dies with no log line, identical
# symptom to the empty-glob case fixed in xcesp-on-rtr 0.0.158.
#
# These files only contain plugin enable/disable defaults (e.g.
# `aes { load = yes }`) — no secrets — so making them world-readable
# is safe.  Re-applied on every activate run so an `apt upgrade` that
# re-tightens perms is self-healed at the next xcespproc start.
# Both candidate paths (Fedora `/etc/strongswan/strongswan.d/charon`
# and Debian/Ubuntu `/etc/strongswan.d/charon`) are handled.
# ---------------------------------------------------------------------------
for plugin_dir in /etc/strongswan/strongswan.d/charon \
                  /etc/strongswan.d/charon; do
    [ -d "$plugin_dir" ] || continue
    chmod a+rx "$plugin_dir" 2>/dev/null || true
    chmod a+r  "$plugin_dir"/*.conf 2>/dev/null || true
    log "  relaxed perms on $plugin_dir/*.conf for xcesp readability"
done

# ---------------------------------------------------------------------------
# 802.1X supplicant / authenticator capabilities
#
# wpa_supplicant (per-interface) and hostapd (per-VRF, future) both need to
# receive EAPOL frames at the link layer and bind PF_PACKET sockets.  When
# xcespproc launches them inside a named netns, the kernel applies the
# *file* caps on the binary at exec time — so we set both
# CAP_NET_ADMIN (configure the iface) and CAP_NET_RAW (raw/packet sockets)
# on the binaries themselves.  This survives `ip netns exec` losing the
# ambient set (the NAT capability-wipe lesson from xcespproc 0.1.6).
#
# Re-applied on every activate run, idempotent.
# ---------------------------------------------------------------------------
if command -v setcap > /dev/null 2>&1; then
    # Non-destructive setcap: only fills in caps when the binary currently has
    # NONE.  Distros that ship caps on these daemons (Fedora's dhcp-client RPM,
    # Debian Bookworm's isc-dhcp-client deb) keep their carefully-tuned set.
    # Distros that don't (Ubuntu's stock packages, fresh Debian 13) get our
    # baseline so the binary works under xcespproc's launch chain.
    #
    # Previously (xcesppkg 0.1.92) we unconditionally setcap'd these
    # binaries, which on Fedora/Debian REPLACED the package-shipped caps
    # with a strict subset and broke DHCP on every install.  Hence the
    # gating check below.
    #
    # 802.1X daemons — need PF_PACKET sockets for EAPOL.  We tried the
    # file-caps approach first (cap_net_admin,cap_net_raw=ep on both bins),
    # and it works on the dev box but Fedora silently refuses to activate
    # those caps when xcespproc execs the daemons as the xcesp uid: getcap
    # shows them, NoNewPrivs is 0, getenforce is Permissive, no AVCs, and
    # cgroup-BPF is empty — yet PF_PACKET bind() returns EPERM.  Identical
    # symptom to Ubuntu's libcap-less charon (xcesppkg 0.1.72), and the
    # same fix works: strip the file caps and setuid-root the binary
    # instead.  setuid elevates uid→0 on exec → kernel grants full caps
    # without depending on file-cap activation.  hostapd / wpa_supplicant
    # drop privileges internally once the wired driver is up, so the
    # privilege window is short.
    for wpa_bin in /usr/sbin/wpa_supplicant \
                   /sbin/wpa_supplicant \
                   /usr/local/sbin/wpa_supplicant \
                   /usr/bin/wpa_supplicant; do
        [ -f "$wpa_bin" ] || continue
        cur_caps="$(getcap "$wpa_bin" 2>/dev/null)"
        cur_mode="$(stat -c %a "$wpa_bin" 2>/dev/null)"
        if [ -n "$cur_caps" ]; then
            setcap -r "$wpa_bin" 2>/dev/null || true
            log "  setcap -r applied to $wpa_bin (had: $cur_caps)"
        fi
        case "$cur_mode" in
            4*) log "  $wpa_bin already setuid; leaving alone" ;;
            *)  chmod u+s "$wpa_bin" 2>/dev/null && log "  chmod u+s applied to $wpa_bin" ;;
        esac
    done
    for hostapd_bin in /usr/sbin/hostapd \
                       /sbin/hostapd \
                       /usr/local/sbin/hostapd \
                       /usr/bin/hostapd; do
        [ -f "$hostapd_bin" ] || continue
        cur_caps="$(getcap "$hostapd_bin" 2>/dev/null)"
        cur_mode="$(stat -c %a "$hostapd_bin" 2>/dev/null)"
        if [ -n "$cur_caps" ]; then
            setcap -r "$hostapd_bin" 2>/dev/null || true
            log "  setcap -r applied to $hostapd_bin (had: $cur_caps)"
        fi
        case "$cur_mode" in
            4*) log "  $hostapd_bin already setuid; leaving alone" ;;
            *)  chmod u+s "$hostapd_bin" 2>/dev/null && log "  chmod u+s applied to $hostapd_bin" ;;
        esac
    done
    # dhclient is special — we make it setuid root and strip file caps.  When
    # xcespproc (running as xcesp uid) forks dhclient, the setuid bit elevates
    # to root, and dhclient's fork-exec of /usr/bin/xcesp-dhclient-script runs
    # the script as root too.  As root, the script's `/sbin/ip` calls have all
    # the caps they need without depending on file caps on `ip` (which Debian
    # ships cap-less).  Same pattern we use for charon (xcesppkg 0.1.72).
    #
    # Why not just file caps on dhclient?  We tried (0.1.95).  Worked on ARM64
    # Ubuntu but failed on Debian: dhclient running as xcesp uid with file caps
    # got `bound to X.X.X.X` but the lease-file write got EACCES through some
    # interaction we couldn't pin down — apparmor profile in complain mode,
    # local override granting /var/lib/xcesp/** rwk, no obvious denial, yet the
    # write failed.  Setuid-root sidesteps the entire issue.
    for dh in /usr/sbin/dhclient /sbin/dhclient /usr/local/sbin/dhclient; do
        [ -f "$dh" ] || continue
        # Only act when it isn't already setuid root with no caps.  Avoid
        # repeatedly toggling on every service restart.
        cur_caps="$(getcap "$dh" 2>/dev/null)"
        cur_mode="$(stat -c %a "$dh" 2>/dev/null)"
        if [ -n "$cur_caps" ]; then
            setcap -r "$dh" 2>/dev/null || true
            log "  setcap -r applied to $dh (had: $cur_caps)"
        fi
        case "$cur_mode" in
            4*) log "  $dh already setuid; leaving alone" ;;
            *)  chmod u+s "$dh" 2>/dev/null && log "  chmod u+s applied to $dh" ;;
        esac
    done

    # dhcrelay, dnsmasq, kea — still use the file-caps pattern.  They run their
    # own daemons that need raw sockets / privileged ports but don't spawn a
    # script chain that re-elevates, so caps in pE are enough.
    for dhcp_bin in /usr/sbin/dhcrelay /sbin/dhcrelay \
                    /usr/sbin/dnsmasq  /sbin/dnsmasq /usr/bin/dnsmasq \
                    /usr/sbin/kea-dhcp6 /usr/sbin/kea-dhcp6-server \
                    /usr/local/sbin/dhcrelay \
                    /usr/local/sbin/dnsmasq; do
        [ -f "$dhcp_bin" ] || continue
        if [ -z "$(getcap "$dhcp_bin" 2>/dev/null)" ]; then
            setcap cap_net_bind_service,cap_net_raw,cap_net_admin=ep "$dhcp_bin" \
                2>/dev/null || true
            log "  setcap cap_net_bind_service,cap_net_raw,cap_net_admin applied to $dhcp_bin (was empty)"
        else
            log "  $dhcp_bin already has file caps; leaving alone"
        fi
    done

    # chronyd needs cap_net_bind_service to bind NTP port 123 plus its
    # command-socket port 323 (both privileged).  xcespproc raises
    # cap_net_bind_service via ambient before exec, but chronyd calls
    # setuid(chrony) at startup, and on some distros (Fedora 41 / chrony
    # 4.6.1 seen in the wild) the cap path is lost across that setuid —
    # chronyd logs "Could not open NTP socket on X.X.X.X:123" /
    # "Could not open command socket on 127.0.0.1:323".  Granting the
    # cap on the binary directly is portable across distros.
    for chronyd_bin in /usr/sbin/chronyd /sbin/chronyd \
                       /usr/local/sbin/chronyd; do
        [ -f "$chronyd_bin" ] || continue
        if [ -z "$(getcap "$chronyd_bin" 2>/dev/null)" ]; then
            setcap cap_net_bind_service,cap_net_raw=ep "$chronyd_bin" \
                2>/dev/null || true
            log "  setcap cap_net_bind_service,cap_net_raw applied to $chronyd_bin (was empty)"
        else
            log "  $chronyd_bin already has file caps; leaving alone"
        fi
    done

    # xcesp-ip — privileged wrapper used by xcesp-dhclient-script when the
    # script runs as the xcesp uid with no caps (which happens because ISC
    # dhclient drops privileges before invoking the script).  The wrapper
    # carries `cap_net_admin,cap_net_raw=ep` and re-execs /usr/bin/ip with
    # ambient raised, so the script's `ip addr add` works without giving
    # /usr/bin/ip itself host-wide caps.  Apply non-destructively.
    if [ -f /usr/lib/xcesp/xcesp-ip ]; then
        cur="$(getcap /usr/lib/xcesp/xcesp-ip 2>/dev/null)"
        if [ -z "$cur" ]; then
            setcap cap_net_admin,cap_net_raw=ep /usr/lib/xcesp/xcesp-ip 2>/dev/null || true
            log "  setcap cap_net_admin,cap_net_raw=ep applied to /usr/lib/xcesp/xcesp-ip"
        else
            log "  /usr/lib/xcesp/xcesp-ip already has file caps; leaving alone"
        fi
    fi
fi

# Ensure /var/lib/dhcp exists for dhclient lease files (some minimal images
# lack the isc-dhcp-client package's default /var/lib/dhcp).  We write lease
# files there because the path matches the upstream apparmor profile's
# existing `/var/lib/dhcp{,3}/dhclient* lrw,` rule.
mkdir -p /var/lib/dhcp 2>/dev/null || true
# Mode 0775 (group-writable), NOT 0755. dhclient running in the SELinux
# dhcpc_t domain is denied CAP_DAC_OVERRIDE on Fedora; with 0755 the
# euid=0 process cannot bypass the dir-perm check when neither uid nor
# gid matches the owner. fsgid is inherited as xcesp from the launcher,
# so group-writable lets dhclient create the lease via group perms
# without needing dac_override. Symptom of 0755: dhclient logs
# "can't create /var/lib/dhcp/...: Permission denied", binds the lease
# in memory (DHCP still works), but the on-disk lease never persists.
chmod 0775 /var/lib/dhcp 2>/dev/null || true
# Chown the directory to the xcesp uid so xcespproc can unlink the
# stale lease file on first startDhclient() launch
# (RtrDhcpClient::firstLaunch_ wipe).  Without this, the directory
# stays root:root 755, the unlink silently EACCES's, and dhclient
# starts in INIT-REBOOT against a lease whose server no longer
# exists — never sending a fresh DISCOVER through the relay.
# dhclient is setuid root and still creates files here even after
# we change the directory owner.
chown "$XCESP_USER:$XCESP_GROUP" /var/lib/dhcp 2>/dev/null || true

# SELinux: ISC dhclient on Fedora runs in dhcpc_t and must write its lease
# file (/var/lib/dhcp/dhclient-xcesp-<ns>-<dev>-v4.leases) into a
# dhcpc_state_t-labeled directory.  Fedora's distro default for /var/lib/dhcp
# is dhcp_state_t (server-side); mkdir without restorecon leaves it var_lib_t.
# Either label denies dhcpc_t from creating files in there → dhclient logs
# "can't create ...leases: Permission denied", binds the lease in memory
# (functional DHCP still works), but the on-disk lease never persists.
# Override the fcontext entry for the whole subtree and restorecon so the
# write path lands cleanly.  No-op when SELinux is Disabled.
if command -v getenforce > /dev/null 2>&1 \
        && [ "$(getenforce 2>/dev/null)" != "Disabled" ]; then
    if command -v semanage > /dev/null 2>&1; then
        semanage fcontext -a -t dhcpc_state_t '/var/lib/dhcp(/.*)?' 2>/dev/null \
        || semanage fcontext -m -t dhcpc_state_t '/var/lib/dhcp(/.*)?' 2>/dev/null \
        || true
        restorecon -R /var/lib/dhcp 2>/dev/null || true
        log "  SELinux fcontext: /var/lib/dhcp → dhcpc_state_t (persistent)"
    elif command -v chcon > /dev/null 2>&1; then
        chcon -R -t dhcpc_state_t /var/lib/dhcp 2>/dev/null || true
        log "  SELinux chcon: /var/lib/dhcp → dhcpc_state_t (non-persistent)"
    fi
fi

# SELinux: label xcesp-ip as ifconfig_exec_t so dhcpc_t (the xcesp-dhclient
# -script domain) can exec it and the resulting process gets a domain that's
# already allowed cap_net_admin in Fedora's targeted policy.  Without this,
# the wrapper would default to `lib_t` and dhcpc_t couldn't exec it, OR it
# would stay in dhcpc_t which doesn't have all the caps Linux gave it.
if [ -x /usr/lib/xcesp/xcesp-ip ] && command -v getenforce > /dev/null 2>&1 \
        && [ "$(getenforce 2>/dev/null)" != "Disabled" ]; then
    if command -v semanage > /dev/null 2>&1; then
        semanage fcontext -a -t ifconfig_exec_t "/usr/lib/xcesp/xcesp-ip" 2>/dev/null \
        || semanage fcontext -m -t ifconfig_exec_t "/usr/lib/xcesp/xcesp-ip" 2>/dev/null \
        || true
        restorecon -v /usr/lib/xcesp/xcesp-ip 2>/dev/null || true
        log "  SELinux fcontext: /usr/lib/xcesp/xcesp-ip → ifconfig_exec_t (persistent)"
    elif command -v chcon > /dev/null 2>&1; then
        chcon -t ifconfig_exec_t /usr/lib/xcesp/xcesp-ip 2>/dev/null || true
        log "  SELinux chcon: /usr/lib/xcesp/xcesp-ip → ifconfig_exec_t (non-persistent)"
    fi
fi

# Runtime tmpfs dirs (recreated on every boot) for daemon PID + conf files.
# wpa_supplicant's own ctrl_interface defaults to /run/wpa_supplicant; xcesp's
# per-port conf and pid go under /run/xcesp/dot1x-sup/<ns>/<dev>/ — that
# subtree is created by the PObj as needed, no static skeleton required.
mkdir -p /run/wpa_supplicant 2>/dev/null || true
chmod 0755 /run/wpa_supplicant 2>/dev/null || true

# ---------------------------------------------------------------------------
# AppArmor — local profile additions for distro-shipped daemons
#
# Debian (and derivatives) ships AppArmor profiles for several daemons that
# xcespproc invokes — most notably dhclient.  The default profile confines
# writes to /var/lib/dhcp/, /var/run/, etc., and refuses /var/lib/xcesp/**
# or /run/xcesp/** that we use for per-iface conf/pid/leases.  When apparmor
# is enforcing, dhclient logs "Permission denied" on the lease/pid files,
# the PID file never lands, xcespproc's supervisor sees "not running" and
# relaunches every tick — accumulating zombie processes and stale leases.
#
# Fix: drop xcesp path allowances into /etc/apparmor.d/local/<profile>,
# which the upstream Debian profile already #includes.  Reload the profile
# so the change takes effect without a reboot.  Idempotent.
#
# Adding more daemons: append a "local override" stanza per profile-name.
# ---------------------------------------------------------------------------
apply_apparmor_local() {
    # Argument is the absolute path to the binary the profile confines,
    # e.g. "/usr/sbin/dhclient".  We auto-detect the on-disk profile
    # filename because distros disagree: Debian names the dhclient profile
    # "usr.sbin.dhclient", others have used "sbin.dhclient".  Hardcoding
    # the wrong name made the helper silently no-op on Debian 13.
    local bin_path="$1"
    [ -d /etc/apparmor.d ] || return 0
    # Find a profile file under /etc/apparmor.d/ (top level only — local/
    # files don't define profiles) that mentions this binary path.  Match
    # both the literal path and the curly-brace glob form ("{,usr/}sbin/...")
    # that Debian uses.
    local bin_base
    bin_base=$(basename "$bin_path")
    local profile_file=""
    local cand
    # Top-level *<binbase>* files in /etc/apparmor.d/ are the candidate
    # profile files.  Skip /etc/apparmor.d/local/* (those are includes, not
    # standalone profiles) and skip any candidate that doesn't actually
    # mention the binary name (defensive against unrelated files).
    for cand in /etc/apparmor.d/*"$bin_base"*; do
        [ -f "$cand" ] || continue
        if grep -q "$bin_base" "$cand" 2>/dev/null; then
            profile_file="$cand"
            break
        fi
    done
    if [ -z "$profile_file" ]; then
        log "  AppArmor: no profile file found for $bin_path (skipping local override)"
        return 0
    fi
    local profile_name
    profile_name=$(basename "$profile_file")
    local local_file="/etc/apparmor.d/local/$profile_name"
    mkdir -p /etc/apparmor.d/local
    # Atomic write: only update if content differs.  Required allowances
    # cover every xcesp runtime/persistent path; rw lets the daemon read its
    # own state on relaunch, k lets it lock the file.
    #
    # Per-binary extras:
    #   /usr/sbin/dhclient — needs to exec /usr/bin/xcesp-dhclient-script
    #     (passed via `-sf`).  Without this rule AppArmor denies the execv;
    #     dhclient logs "bound" on DHCPACK but the script never runs, so
    #     the iface never gets an IP.  `rUx` = read + unconfined-execute,
    #     so the script (and the /sbin/ip calls it makes) run without
    #     AppArmor confinement.
    local extras=""
    case "$bin_path" in
        */dhclient) extras='/usr/bin/xcesp-dhclient-script rUx,'$'\n' ;;
    esac
    local desired='# managed by xcesp-activate — extends '"$profile_name"' for xcesp paths
/var/lib/xcesp/** rwk,
/run/xcesp/** rwk,
'"$extras"
    if [ ! -f "$local_file" ] || ! diff -q <(printf %s "$desired") "$local_file" > /dev/null 2>&1; then
        printf %s "$desired" > "$local_file"
        log "  wrote AppArmor local override $local_file (for $bin_path)"
    fi
    # Reparse the profile so the kernel picks up the local include.  -r
    # replaces the existing profile in-place; idempotent and safe.
    if command -v apparmor_parser > /dev/null 2>&1; then
        apparmor_parser -r "$profile_file" 2>/dev/null || true
        log "  reloaded AppArmor profile $profile_name"
    fi
}

if command -v apparmor_parser > /dev/null 2>&1 || [ -d /etc/apparmor.d ]; then
    apply_apparmor_local /usr/sbin/dhclient
    # chronyd on Debian/Ubuntu ships with an AppArmor profile that allows
    # reading /etc/chrony/* and writing /var/lib/chrony/* but knows nothing
    # about our per-namespace runtime path /run/xcesp/ntp/<ns>/chrony.conf.
    # Without a local override chronyd dies with `Fatal error : Could not
    # open /run/xcesp/ntp/<ns>/chrony.conf : Permission denied` and the
    # supervisor respawn-loops.  The xcesp paths grant from
    # apply_apparmor_local (/var/lib/xcesp/** + /run/xcesp/** rwk) covers
    # everything chronyd needs.
    apply_apparmor_local /usr/sbin/chronyd
    # kea-dhcp6 on Debian/Ubuntu ships an AppArmor profile that locks
    # writes to /var/lib/kea, /var/log/kea, /run/kea.  Our RtrDhcpServerV6
    # PObj uses KEA_* env-var overrides to point kea at /run/xcesp/dhcp6/
    # and /var/lib/xcesp/dhcp6/ instead — kea honours the env vars, but
    # the kernel still applies AppArmor.  Without the override kea bails
    # at startup with `Unable to use interprocess sync lockfile
    # (Permission denied): /run/xcesp/dhcp6/.../logger_lockfile` even
    # though the dir is xcesp-owned mode 0750.  The xcesp paths grant
    # from apply_apparmor_local covers everything kea needs.
    apply_apparmor_local /usr/sbin/kea-dhcp6
fi

# ---------------------------------------------------------------------------
# SELinux — relabel xcesp-dhclient-script so dhclient can exec it
#
# Fedora/RHEL ship dhclient confined to the `dhcpc_t` domain, which is only
# allowed to `execute_no_trans` files labeled `dhcpc_exec_t` (or a few other
# specific types).  Our script at /usr/bin/xcesp-dhclient-script defaults to
# `bin_t` after install → dhclient's exec fails silently (the targeted policy
# ships a `dontaudit` rule for this class of denial, so no AVC entry appears).
#
# Persistent fix: add an fcontext rule and restorecon.  Falls back to chcon
# if semanage isn't available (semanage lives in policycoreutils-python-utils
# on Fedora; not always installed).
if [ -x /usr/bin/xcesp-dhclient-script ] && command -v getenforce > /dev/null 2>&1 \
        && [ "$(getenforce 2>/dev/null)" != "Disabled" ]; then
    if command -v semanage > /dev/null 2>&1; then
        semanage fcontext -a -t dhcpc_exec_t "/usr/bin/xcesp-dhclient-script" 2>/dev/null \
        || semanage fcontext -m -t dhcpc_exec_t "/usr/bin/xcesp-dhclient-script" 2>/dev/null \
        || true
        restorecon -v /usr/bin/xcesp-dhclient-script 2>/dev/null || true
        log "  SELinux fcontext: /usr/bin/xcesp-dhclient-script → dhcpc_exec_t (persistent)"
    elif command -v chcon > /dev/null 2>&1; then
        chcon -t dhcpc_exec_t /usr/bin/xcesp-dhclient-script 2>/dev/null || true
        log "  SELinux chcon: /usr/bin/xcesp-dhclient-script → dhcpc_exec_t (non-persistent)"
    fi
fi

# ---------------------------------------------------------------------------
# Schema
# ---------------------------------------------------------------------------
if [ -d "$MAINSW/schema" ]; then
    mkdir -p "$XCESP_BASE/schema"
    cp -rT "$MAINSW/schema" "$XCESP_BASE/schema"
    chown -R "$XCESP_USER:$XCESP_GROUP" "$XCESP_BASE/schema"
    find "$XCESP_BASE/schema" -type d -exec chmod 0755 {} \;
    find "$XCESP_BASE/schema" -type f -exec chmod 0644 {} \;
    log "  schema synced"
fi

# ---------------------------------------------------------------------------
# Python rules
# ---------------------------------------------------------------------------
if [ -d "$MAINSW/rules" ]; then
    mkdir -p "$XCESP_BASE/rules"
    cp -rT "$MAINSW/rules" "$XCESP_BASE/rules"
    chown -R "$XCESP_USER:$XCESP_GROUP" "$XCESP_BASE/rules"
    find "$XCESP_BASE/rules" -type d  -exec chmod 0755 {} \;
    find "$XCESP_BASE/rules" -type f -name "*.py" -exec chmod 0755 {} \;
    log "  rules synced"
fi

# ---------------------------------------------------------------------------
# xcesppy in venv (fast reinstall — pure Python, no external deps)
# ---------------------------------------------------------------------------
VENV=$XCESP_BASE/venv
if [ -d "$MAINSW/python" ] && [ -d "$VENV" ]; then
    "$VENV/bin/pip" install --quiet "$MAINSW/python" 2>/dev/null && \
        log "  xcesppy updated in venv" || \
        log "  WARNING: xcesppy venv update failed (non-fatal)"
fi

# ---------------------------------------------------------------------------
# FRR group write access — needed so xcespproc can create /etc/frr/<ns>/
# ---------------------------------------------------------------------------
# /etc/frr is owned by frr:frr.  xcespproc runs as the xcesp user (which is
# added to the frr group by install.sh).  Ensure group write is set on every
# start so that "dnf install frr" after the initial install.sh still works.
if getent group frr > /dev/null 2>&1 && [ -d /etc/frr ]; then
    # Add xcesp to frr group if not already there (idempotent)
    if ! id -Gn "$XCESP_USER" 2>/dev/null | grep -qw frr; then
        usermod -aG frr "$XCESP_USER"
        log "  added $XCESP_USER to frr group"
    fi
    chmod g+rwx /etc/frr
    log "  /etc/frr: group write ensured"

    # Install/refresh frrinit.sh + vtysh sudoers rule.
    # frrinit.sh unconditionally requires EUID=0; xcespproc invokes it via sudo -n.
    # Re-run on every activation so that "dnf install frr" after the initial
    # install.sh is handled without a reinstall.
    FRRINIT=""
    for candidate in /usr/libexec/frr/frrinit.sh /usr/lib/frr/frrinit.sh \
                     /usr/local/lib/frr/frrinit.sh; do
        [ -f "$candidate" ] && FRRINIT="$candidate" && break
    done
    VTYSH_BIN="$(command -v vtysh 2>/dev/null || true)"

    if [ -n "$FRRINIT" ] || [ -n "$VTYSH_BIN" ]; then
        FRR_SUDOERS=/etc/sudoers.d/xcesp-frr
        > "$FRR_SUDOERS"
        [ -n "$FRRINIT" ] && \
            echo "$XCESP_USER ALL=(root) NOPASSWD: $FRRINIT *" >> "$FRR_SUDOERS"
        [ -n "$VTYSH_BIN" ] && \
            echo "$XCESP_USER ALL=(root) NOPASSWD: $VTYSH_BIN *" >> "$FRR_SUDOERS"
        chmod 0440 "$FRR_SUDOERS"
        log "  $FRR_SUDOERS refreshed"
    fi
fi

# ---------------------------------------------------------------------------
# Reboot / xcesp-service-restart sudoers rule — refresh on every activation
# ---------------------------------------------------------------------------
# `reboot`, `reboot light`, and `software-install` ultimately need to call
# either `systemctl reboot` or `systemctl restart xcesp` as root.  xcespserver
# (running as xcesp uid) invokes those via `sudo -n`.  Without this rule the
# operator's `reboot` command silently no-ops because `sudo -n` returns 1
# with "a password is required" buried in stderr that we never see.
REBOOT_SUDOERS=/etc/sudoers.d/xcesp-reboot
SYSTEMCTL_BIN="$(command -v systemctl 2>/dev/null || echo /usr/bin/systemctl)"
if [ -x "$SYSTEMCTL_BIN" ]; then
    cat > "$REBOOT_SUDOERS" <<SUDOERS
# Allow xcespserver to restart the xcesp stack and to reboot the host.
# Both flows ride through FileActionHandler::doReboot().
$XCESP_USER ALL=(root) NOPASSWD: $SYSTEMCTL_BIN restart xcesp, \\
                                  $SYSTEMCTL_BIN restart xcesp.service, \\
                                  $SYSTEMCTL_BIN restart xcespwdog, \\
                                  $SYSTEMCTL_BIN restart xcespwdog.service, \\
                                  $SYSTEMCTL_BIN reboot
SUDOERS
    chmod 0440 "$REBOOT_SUDOERS"
    log "  $REBOOT_SUDOERS refreshed"
fi

# ---------------------------------------------------------------------------
# IPsec config directory sudoers rule — refresh on every activation
# ---------------------------------------------------------------------------
# xcespproc uses "sudo -n mkdir -p" to create per-namespace swanctl conf dirs
# under /etc/swanctl/ or /etc/strongswan/swanctl/.  Refresh the rule here so
# that a fresh OS install or upgrade does not leave it missing.
SWAN_SUDOERS=/etc/sudoers.d/xcesp-swan
if [ ! -f "$SWAN_SUDOERS" ]; then
    cat > "$SWAN_SUDOERS" <<'SUDOERS'
# Allow xcespproc to create and own per-namespace IPsec config directories.
xcesp ALL=(root) NOPASSWD: /usr/bin/mkdir -p /etc/swanctl/*, \
                            /usr/bin/mkdir -p /etc/strongswan/swanctl/*, \
                            /usr/bin/mkdir -p /run/strongswan/*, \
                            /usr/bin/chown * /etc/swanctl/*, \
                            /usr/bin/chown * /etc/strongswan/swanctl/*, \
                            /usr/bin/chown * /run/strongswan/*
SUDOERS
    chmod 0440 "$SWAN_SUDOERS"
    log "  $SWAN_SUDOERS installed"
fi

# ---------------------------------------------------------------------------
# Generate xcespwdog process list from xcespserver.conf
# ---------------------------------------------------------------------------
# Reads 'server N / processes routing / count M' and writes one [process.N]
# entry per xcespproc instance into PROC_CONFIG_FILE before xcespwdog starts.
# Default: 2 routing processes if xcespserver.conf has no server/processes block.
WDOG_PROC_FILE=/run/xcesp/xcespwdog_proc.ini
SERVER_CONF=$XCESP_BASE/cfg/xcespserver.conf
DEFAULT_ROUTING_COUNT=2

routing_count=$DEFAULT_ROUTING_COUNT
if [ -f "$SERVER_CONF" ]; then
    # First preference: explicit "processes routing / count N" inside a server block.
    # Use anchored patterns to distinguish indented child "!" from the unindented "!"
    # that closes the server block itself — otherwise a license-code or banner child
    # block's closing "!" would prematurely reset in_server before we reach processes.
    explicit_count=$(awk '
        /^server[[:space:]]/  { in_server=1; in_proc=0; next }
        in_server && /^[[:space:]]+processes[[:space:]]+routing/ { in_proc=1; next }
        in_server && in_proc && /^[[:space:]]+count[[:space:]]+[0-9]+/ {
            match($0, /[0-9]+/); count=substr($0,RSTART,RLENGTH)
        }
        in_server && in_proc && /^[[:space:]]+!/ { in_proc=0; next }
        in_server && /^!/  { in_server=0; next }
        END { if (count) print count }
    ' "$SERVER_CONF")
    if [ -n "$explicit_count" ]; then
        routing_count=$explicit_count
    else
        # Fallback: count top-level "router <name>" blocks — one process per router
        router_count=$(grep -c '^router ' "$SERVER_CONF" 2>/dev/null || echo 0)
        [ "$router_count" -gt 0 ] && routing_count=$router_count
    fi
fi

# Clamp to valid range
{ [ "$routing_count" -lt 1 ] 2>/dev/null && routing_count=1; } || true
{ [ "$routing_count" -gt 64 ] 2>/dev/null && routing_count=64; } || true

log "  xcespwdog_proc.ini: $routing_count routing process(es)"

# NOTE: when PROC_CONFIG_FILE is set, xcespwdog reads ALL process entries from
# this file only (not from xcespwdog.ini). process.1 must be xcespserver here.
{
    echo "# Auto-generated by xcesp-activate — do not edit by hand."
    echo "# To change: edit xcespserver.conf  (server N / processes routing / count M)"
    echo "# then run:  systemctl restart xcesp"
    echo ""
    echo "# process.1 — xcespserver (always present)"
    echo "[process.1]"
    echo "WDOG_LAUNCH             = /usr/bin/xcespserver --config /var/xcesp/cfg/xcespserver.ini"
    echo "WDOG_START_TIMER        = 0"
    echo "WDOG_INTERVAL_TIMER     = 0"
    echo "WDOG_RESPAWN            = true"
    echo "WDOG_RESPAWN_MAXCOUNT   = 3"
    echo ""
    proc_idx=2
    # Timers below match xcespserver's WdogConfigWriter formula
    # (start = heartbeatS * 1500, interval = start * 2).  With heartbeatS=60s
    # → start=90s, interval=180s.  Previously this bootstrap used a 30s
    # heartbeat with a 60s start deadline; xcespproc's main event loop can
    # be starved during the initial CtrlLink DEPLOY callback long enough to
    # miss that 60s deadline → wdog kills xcespproc, cascading dhcrelay/
    # dhclient through their next supervisor cycle.  Matching the
    # heartbeatS / formula across the bootstrap and the xcespserver-
    # generated proc.ini avoids the cliff.
    for i in $(seq 1 "$routing_count"); do
        echo "# xcespproc-$i: affinity $i"
        echo "[process.$proc_idx]"
        echo "WDOG_LAUNCH             = /usr/bin/xcespproc --config /var/xcesp/cfg/xcespproc.ini -i $i -s 60 -p 1514"
        echo "WDOG_START_TIMER        = 90000"
        echo "WDOG_INTERVAL_TIMER     = 180000"
        echo "WDOG_RESPAWN            = true"
        echo "WDOG_RESPAWN_MAXCOUNT   = 3"
        echo ""
        proc_idx=$((proc_idx + 1))
    done
} > "$WDOG_PROC_FILE"

# ---------------------------------------------------------------------------
# doc-httpd process slot — append to xcespwdog_proc.ini if enabled
# ---------------------------------------------------------------------------
# Reads [DOC_HTTPD] from xcespserver.ini (with safe defaults if the section
# is absent — covers in-place upgrades whose existing INI predates the
# feature).  Emits a python3 -m http.server process block that xcespwdog
# supervises just like xcespproc; heartbeat polling disabled because
# python's http.server doesn't speak SIGUSR1.
SERVER_INI=$XCESP_BASE/cfg/xcespserver.ini

# Inject the [DOC_HTTPD] section into xcespserver.ini if missing — same
# idempotent pattern used for PROC_CONFIG_FILE in xcespwdog.ini below.
# This keeps the operator's tunables visible in the standard place once
# the upgrade has run.
if [ -f "$SERVER_INI" ] && ! grep -q '^\[DOC_HTTPD\]' "$SERVER_INI"; then
    cat >> "$SERVER_INI" <<'INI_EOF'

[DOC_HTTPD]
# Static user-manual HTTP server, supervised by xcespwdog.  When ENABLED,
# xcesp-activate emits an extra [process.N] entry into xcespwdog_proc.ini
# that launches `python3 -m http.server` against DOC_DIR.  Disable by
# setting ENABLED = false.  BIND_ADDR defaults to 0.0.0.0 while this is
# INI-only; a future schema/CLI layer will flip the default to 127.0.0.1.
ENABLED   = true
BIND_ADDR = 0.0.0.0
PORT      = 8080
DOC_DIR   = /var/xcesp/doc
INI_EOF
    log "  injected [DOC_HTTPD] defaults into $SERVER_INI"
fi

# Tiny ini-scalar reader: $1 = key, $2 = default.  Reads only inside
# [DOC_HTTPD]; tolerates leading whitespace, blank lines, and `;` / `#`
# inline comments.  POSIX-portable awk (works under mawk and gawk).
read_doc_httpd() {
    local key="$1" def="$2"
    [ -f "$SERVER_INI" ] || { printf '%s' "$def"; return; }
    awk -v key="$key" -v def="$def" '
        BEGIN { in_sect = 0; found = 0 }
        /^[[:space:]]*[;#]/                  { next }
        /^\[DOC_HTTPD\][[:space:]]*$/        { in_sect = 1; next }
        /^\[/                                 { in_sect = 0; next }
        in_sect {
            eq = index($0, "=")
            if (eq == 0) next
            k = substr($0, 1, eq - 1)
            v = substr($0, eq + 1)
            # trim key
            sub(/^[[:space:]]+/, "", k); sub(/[[:space:]]+$/, "", k)
            # trim value: leading ws, trailing inline comment, trailing ws
            sub(/^[[:space:]]+/, "", v)
            sub(/[[:space:]]*[;#].*$/, "", v)
            sub(/[[:space:]]+$/, "", v)
            if (k == key) { print v; found = 1; exit }
        }
        END { if (!found) print def }
    ' "$SERVER_INI"
}

doc_enabled=$(read_doc_httpd ENABLED   true)
doc_addr=$(read_doc_httpd    BIND_ADDR 0.0.0.0)
doc_port=$(read_doc_httpd    PORT      8080)
doc_dir=$(read_doc_httpd     DOC_DIR   /var/xcesp/doc)

if [ "$doc_enabled" = "true" ] && [ -d "$doc_dir" ]; then
    {
        echo ""
        echo "# doc-httpd — static user-manual server (python3 -m http.server)"
        echo "[process.$proc_idx]"
        echo "WDOG_LAUNCH             = python3 -m http.server --bind $doc_addr --directory $doc_dir $doc_port"
        echo "WDOG_START_TIMER        = 0"
        echo "WDOG_INTERVAL_TIMER     = 0"
        echo "WDOG_RESPAWN            = true"
        echo "WDOG_RESPAWN_MAXCOUNT   = 3"
    } >> "$WDOG_PROC_FILE"
    log "  doc-httpd enabled: $doc_addr:$doc_port → $doc_dir"
elif [ "$doc_enabled" = "true" ]; then
    log "  doc-httpd skipped: DOC_DIR $doc_dir does not exist"
else
    log "  doc-httpd disabled in xcespserver.ini"
fi

chown "$XCESP_USER:$XCESP_GROUP" "$WDOG_PROC_FILE"
chmod 0640 "$WDOG_PROC_FILE"

# Patch existing xcespserver.ini installations that pre-date MANAGED_USERS_FILE
# support (xcesppkg 0.2.2+).  install.sh only writes xcespserver.ini if the file
# does not already exist (non-destructive), so a VM that was first installed
# with an earlier xcesppkg keeps its INI verbatim and loses the new key.
# Without MANAGED_USERS_FILE, xcespserver silently skips writing
# /var/lib/xcesp/managed-users.state and the AAA section below has nothing
# to consume — `sshd-integration true` looks like it does nothing at all.
SERVER_INI=$XCESP_BASE/cfg/xcespserver.ini
if [ -f "$SERVER_INI" ]; then
    if ! grep -q "^MANAGED_USERS_FILE" "$SERVER_INI"; then
        # Insert after DEPLOY_BATCH_SIZE (last line of the tuning block in the
        # shipped template).  Fall back to inserting at the end of [SERVER]
        # if the anchor line is absent.
        if grep -q "^DEPLOY_BATCH_SIZE" "$SERVER_INI"; then
            sed -i '/^DEPLOY_BATCH_SIZE/a MANAGED_USERS_FILE   = /var/lib/xcesp/managed-users.state' "$SERVER_INI"
        else
            # Insert immediately before the first non-[SERVER] section header,
            # or at end-of-file if [SERVER] is the only section.
            awk '
                BEGIN { inserted=0; in_server=0 }
                /^\[SERVER\]/  { in_server=1; print; next }
                /^\[/ && in_server && !inserted { print "MANAGED_USERS_FILE   = /var/lib/xcesp/managed-users.state"; inserted=1; in_server=0 }
                { print }
                END { if (in_server && !inserted) print "MANAGED_USERS_FILE   = /var/lib/xcesp/managed-users.state" }
            ' "$SERVER_INI" > "$SERVER_INI.tmp" && mv "$SERVER_INI.tmp" "$SERVER_INI"
            chown "$XCESP_USER:$XCESP_GROUP" "$SERVER_INI"
            chmod 0640 "$SERVER_INI"
        fi
        log "  injected MANAGED_USERS_FILE into $SERVER_INI (legacy install)"
    fi
fi

# Patch existing xcespwdog.ini installations that pre-date PROC_CONFIG_FILE support:
# 1. Inject PROC_CONFIG_FILE if missing.
# 2. Remove any static [process.N] entries for xcespproc (N >= 2) — they would
#    collide with the same section names in xcespwdog_proc.ini and prevent startup.
WDOG_INI=$XCESP_BASE/cfg/xcespwdog.ini
if [ -f "$WDOG_INI" ]; then
    if ! grep -q "^PROC_CONFIG_FILE" "$WDOG_INI"; then
        sed -i "/^LOG_LOCAL_PORT/a PROC_CONFIG_FILE        = $WDOG_PROC_FILE" "$WDOG_INI"
        log "  injected PROC_CONFIG_FILE into $WDOG_INI"
    fi
    # Remove static xcespproc [process.N] blocks (process.2 and above).
    # Keep only [process.1] (xcespserver) and the [WDOG] section.
    # Strategy: delete from any [process.N] line where N>=2 through the next
    # [process.M] or end-of-file, using awk.
    cleaned=$(awk '
        /^\[process\.([2-9]|[0-9]{2,})\]/ { skip=1 }
        /^\[process\.1\]/ { skip=0 }
        !skip { print }
    ' "$WDOG_INI")
    if [ "$(echo "$cleaned" | wc -l)" -lt "$(wc -l < "$WDOG_INI")" ]; then
        echo "$cleaned" > "$WDOG_INI"
        log "  removed static xcespproc entries from $WDOG_INI (now managed by PROC_CONFIG_FILE)"
    fi
fi

# ---------------------------------------------------------------------------
# AAA — sync local POSIX users from /var/lib/xcesp/managed-users.state
# ---------------------------------------------------------------------------
# Format of MANAGED_USERS_FILE (v2, written by xcespserver 0.2.4+):
#
#   # xcesp managed-users v2
#   # sshd-integration: true|false
#   # fields: username:role:password-hash:full-name
#   alice:1:$6$salt$hash:Alice Admin
#   bob:3::Bob Operator
#
# Lifecycle (tied to the sshd-integration flag — the user explicitly opts
# into having XCESP touch /etc/ssh/sshd_config and the system user DB):
#
#  ENABLE (sshd-integration: true):
#    1. /etc/ssh/sshd_config.d/50-xcesp.conf is written (Match Group block
#       routing xcespg1..xcespg4 into /usr/lib/xcesp/xcesp-login).
#    2. xcespg1..xcespg4 system groups are created if missing.
#    3. POSIX users are SYNCHRONISED with the state file, bidirectionally:
#       - State → Linux: each state user is created or fixed up (primary
#         group xcespg<role>, login shell xcesp-login, GECOS, password
#         via `chpasswd -e` or `passwd -l` when no hash).
#       - Linux → State: every account whose primary group is xcespg1..4
#         (or that is a supplementary member of any of those groups) and
#         is NOT in the state file with the matching role is REMOVED.
#         Reserved names (root, xcesp, daemon, bin, sys, nobody) are
#         never touched.
#
#  DISABLE (sshd-integration: false, or no state file at all):
#    1. /etc/ssh/sshd_config.d/50-xcesp.conf is removed.
#    2. Every POSIX account whose primary group is xcespg1..4 (or
#       supplementary member) is REMOVED (reserved names skipped).
#    3. xcespg1..xcespg4 system groups are removed.
#
# The cleanup is intentional and matches the user-facing semantics:
# disabling sshd-integration is the operator saying "I no longer want
# XCESP-managed system accounts" — the system is returned to its
# pre-enable state.  User definitions stay in the running config and
# will re-materialise on the next enable.

MANAGED_USERS_FILE=${MANAGED_USERS_FILE:-/var/lib/xcesp/managed-users.state}
XCESP_LOGIN_BIN=/usr/lib/xcesp/xcesp-login
SSHD_DROPIN=/etc/ssh/sshd_config.d/50-xcesp.conf
XCESP_ROLE_GROUPS="xcespg1 xcespg2 xcespg3 xcespg4"

# Reserved names that we must never create, modify, or remove regardless
# of what the state file or system groups claim — defence in depth in case
# a future bug puts a critical account in xcespg1..4 by mistake.
xcesp_aaa_reserved() {
    case "$1" in
        root|xcesp|daemon|bin|sys|nobody) return 0 ;;
        *) return 1 ;;
    esac
}

# Echo every account whose primary group is one of xcespg1..4 OR that is
# a supplementary member of any of them, one username per line, sorted +
# deduplicated.  Used to discover the set of XCESP-managed POSIX users
# from the system side (independent of the state file).
xcesp_aaa_collect_system_users() {
    {
        for g in $XCESP_ROLE_GROUPS; do
            gid=$(getent group "$g" 2>/dev/null | awk -F: '{print $3}')
            if [ -n "$gid" ]; then
                # Primary-group members.
                getent passwd | awk -F: -v gid="$gid" '$4 == gid {print $1}'
            fi
            # Supplementary-group members (group entry's 4th field is a comma list).
            getent group "$g" 2>/dev/null | awk -F: '{print $4}' | tr ',' '\n' | grep -v '^$' || true
        done
    } | sort -u
}

# Remove a managed account safely.  Refuses reserved names.  Logs the
# removal so a diff-able xcesp-activate run is auditable.
xcesp_aaa_remove_user() {
    local u="$1"
    local reason="$2"
    if xcesp_aaa_reserved "$u"; then
        log "  skipping reserved name '$u' (${reason})"
        return 0
    fi
    if ! id "$u" >/dev/null 2>&1; then
        return 0
    fi
    # Prefer removing the home dir so a re-create with the same name
    # starts clean.  If userdel -r fails (e.g. dir gone, processes
    # owning it), fall back to userdel without -r.
    if userdel -r "$u" 2>/dev/null; then
        log "  removed user $u (${reason})"
    elif userdel "$u" 2>/dev/null; then
        log "  removed user $u (no home cleanup, ${reason})"
    else
        log "  WARNING: userdel failed for $u (${reason})"
    fi
}

# --- Determine desired state ------------------------------------------------
# When the state file exists we trust it; otherwise we behave as if
# sshd-integration is false (so an uninstall / `aaa` removal from config
# correctly tears the system back down).

sshd_integration=false
state_present=false
state_format_ok=false
declare -A state_user_role
declare -A state_user_password
declare -A state_user_fullname
state_users_ordered=""

if [ -f "$MANAGED_USERS_FILE" ]; then
    state_present=true
    head_line=$(head -1 "$MANAGED_USERS_FILE")
    case "$head_line" in
        "# xcesp managed-users v2")
            state_format_ok=true
            ;;
        "# xcesp managed-users v1")
            log "AAA: $MANAGED_USERS_FILE is v1 (legacy from 0.2.2) — ignoring; xcespserver 0.2.4+ will rewrite as v2 on next commit"
            ;;
        *)
            log "AAA: refusing to process $MANAGED_USERS_FILE — bad magic header"
            ;;
    esac
fi

if [ "$state_format_ok" = "true" ]; then
    # Parse sshd-integration from the header comment (always present in v2).
    si=$(grep -m1 '^# sshd-integration:' "$MANAGED_USERS_FILE" | awk -F': *' '{print $2}' | tr -d '[:space:]')
    [ "$si" = "true" ] && sshd_integration=true

    # Parse user lines (skip comments / blank).
    while IFS=: read -r u_name u_role u_pw u_full; do
        [ -z "$u_name" ] && continue
        case "$u_name" in '#'*) continue ;; esac
        state_user_role["$u_name"]="$u_role"
        state_user_password["$u_name"]="$u_pw"
        state_user_fullname["$u_name"]="$u_full"
        state_users_ordered="$state_users_ordered $u_name"
    done < "$MANAGED_USERS_FILE"
fi

if [ "$state_present" = "false" ]; then
    log "AAA: no state file at $MANAGED_USERS_FILE — treating as sshd-integration=false (cleanup)"
fi

# --- ENABLE path -----------------------------------------------------------
if [ "$sshd_integration" = "true" ]; then
    log "AAA: sshd-integration=true — sync mode"

    # 1. sshd_config drop-in (Pre-activate: ensure XCESPG group logic exists).
    mkdir -p /etc/ssh/sshd_config.d
    desired_dropin=$(cat <<'SSHEOF'
# BEGIN xcesp — managed by xcesp-activate, do not edit
#
# Route members of xcespg1..xcespg4 directly into xcespcli on login.
# Removing or commenting `Match Group ...` would let these users access
# a normal shell, which is not what the AAA model intends.

Match Group xcespg1,xcespg2,xcespg3,xcespg4
    ForceCommand /usr/lib/xcesp/xcesp-login
    PermitTTY yes
    X11Forwarding no
    AllowTcpForwarding no
    PermitTunnel no
# END xcesp
SSHEOF
    )
    current_dropin=""
    [ -f "$SSHD_DROPIN" ] && current_dropin=$(cat "$SSHD_DROPIN")
    if [ "$current_dropin" != "$desired_dropin" ]; then
        printf '%s\n' "$desired_dropin" > "$SSHD_DROPIN"
        chmod 0644 "$SSHD_DROPIN"
        log "  installed $SSHD_DROPIN (sshd-integration=true)"
        systemctl reload sshd 2>/dev/null || systemctl reload ssh 2>/dev/null || true
    fi

    # 2. Ensure the four role groups exist.
    for g in $XCESP_ROLE_GROUPS; do
        if ! getent group "$g" >/dev/null; then
            groupadd -r "$g"
            log "  created group $g"
        fi
    done

    # 3. State → Linux: create or fix up each user in the state file.
    for u_name in $state_users_ordered; do
        if xcesp_aaa_reserved "$u_name"; then
            log "  skipping reserved name '$u_name' (in state file)"
            continue
        fi
        u_role="${state_user_role[$u_name]}"
        u_pw="${state_user_password[$u_name]}"
        u_full="${state_user_fullname[$u_name]}"

        case "$u_role" in 1|2|3|4) ;; *) u_role=1 ;; esac
        grp="xcespg${u_role}"
        shell="$XCESP_LOGIN_BIN"

        if id "$u_name" >/dev/null 2>&1; then
            current_gid=$(id -g "$u_name")
            desired_gid=$(getent group "$grp" | awk -F: '{print $3}')
            if [ "$current_gid" != "$desired_gid" ]; then
                usermod -g "$grp" "$u_name"
                log "  $u_name: primary group → $grp"
            fi
            current_shell=$(getent passwd "$u_name" | awk -F: '{print $7}')
            if [ "$current_shell" != "$shell" ]; then
                usermod -s "$shell" "$u_name"
                log "  $u_name: shell → $shell"
            fi
            current_gecos=$(getent passwd "$u_name" | awk -F: '{print $5}')
            if [ "$current_gecos" != "$u_full" ]; then
                usermod -c "$u_full" "$u_name"
            fi
        else
            # New account.  Primary group is xcespg<role> (drives CliRole);
            # supplementary "xcesp" lets the account traverse
            # /var/run/xcesp/ and read ctrl.sock — without it the
            # ForceCommand xcesp-login → xcespcli connection fails with
            # "Connection failed" because the socket dir is mode 0750
            # xcesp:xcesp.
            useradd --create-home --shell "$shell" \
                    -g "$grp" -G "$XCESP_USER" \
                    --comment "$u_full" "$u_name"
            log "  created user $u_name (group=$grp +$XCESP_USER shell=$shell)"
        fi

        # Always re-assert membership in the `xcesp` supplementary group —
        # `usermod -aG` is additive and idempotent.  Covers both freshly
        # created accounts (where useradd -G already set it) and existing
        # accounts that pre-date the 0.2.6 fix.
        if ! id -nG "$u_name" 2>/dev/null | tr ' ' '\n' | grep -qx "$XCESP_USER"; then
            usermod -aG "$XCESP_USER" "$u_name"
            log "  $u_name: + supplementary group $XCESP_USER"
        fi

        if [ -n "$u_pw" ]; then
            echo "$u_name:$u_pw" | chpasswd -e
        else
            passwd -l "$u_name" >/dev/null
        fi
    done

    # 4. Linux → State: remove any Linux account whose primary group is
    #    xcespg1..4 (or that is a supplementary member) and whose name or
    #    role does NOT match the state file.
    system_xcesp_users=$(xcesp_aaa_collect_system_users)
    for u in $system_xcesp_users; do
        if xcesp_aaa_reserved "$u"; then continue; fi
        if [ -n "${state_user_role[$u]+set}" ]; then
            # User is in state.  Check primary group matches the configured role.
            expected_gid=$(getent group "xcespg${state_user_role[$u]}" | awk -F: '{print $3}')
            current_gid=$(id -g "$u" 2>/dev/null || echo "")
            if [ "$current_gid" != "$expected_gid" ]; then
                # Primary group still wrong (e.g. only-supplementary member of
                # a different xcespg).  usermod above already fixed primary
                # group for state users; if this fires it means the account
                # was a supplementary member of xcespgX for a role it doesn't
                # hold — strip the supplementary memberships.
                for g in $XCESP_ROLE_GROUPS; do
                    if [ "$g" != "xcespg${state_user_role[$u]}" ]; then
                        gpasswd -d "$u" "$g" >/dev/null 2>&1 || true
                    fi
                done
            fi
        else
            xcesp_aaa_remove_user "$u" "in xcespgX but not in state file"
        fi
    done
fi

# --- DISABLE path ----------------------------------------------------------
if [ "$sshd_integration" = "false" ]; then
    log "AAA: sshd-integration=false — cleanup mode"

    # 1. Remove the sshd_config drop-in (Pre-activate: strip XCESPG group logic).
    if [ -f "$SSHD_DROPIN" ]; then
        rm -f "$SSHD_DROPIN"
        log "  removed $SSHD_DROPIN (sshd-integration=false)"
        systemctl reload sshd 2>/dev/null || systemctl reload ssh 2>/dev/null || true
    fi

    # 2. Remove every account whose primary group is xcespg1..4 (or that
    #    is a supplementary member).  Reserved names are skipped.
    system_xcesp_users=$(xcesp_aaa_collect_system_users)
    for u in $system_xcesp_users; do
        xcesp_aaa_remove_user "$u" "sshd-integration disabled"
    done

    # 3. Remove the role groups themselves.
    for g in $XCESP_ROLE_GROUPS; do
        if getent group "$g" >/dev/null; then
            groupdel "$g" 2>/dev/null && log "  removed group $g" \
                || log "  WARNING: groupdel failed for $g"
        fi
    done
fi

# ---------------------------------------------------------------------------
# Centralised AAA (TACACS+) — 0.2.10
# ---------------------------------------------------------------------------
# Source of truth: /var/lib/xcesp/aaa-config.state written by xcespserver
# on init/commit.  Format:
#
#   [global]
#   order = local tacacs radius        # PAM auth order (whitespace list)
#
#   [tacacs]
#   present = true
#   key = shared-tacacs-secret
#   timeout = 5
#   servers = 10.0.0.50:49 10.0.0.51:49
#   priv-lvl-map = "15:1 10:2 5:3 0:4"
#
# 0.2.10 pivots away from the libnss-tacplus / libpam-tacplus design used
# in 0.2.9 — Fedora 41 has no `pam_tacplus` / `libnss-tacplus` packages,
# only the unrelated Shrubbery server library.  The new design uses a
# shared local pool account `xcesp-tacacs` + a custom auth tool that
# implements RFC 8907 directly (xcesppkg/scripts/xcesp-tacacs-auth.cpp).
# This works identically on Fedora and Debian; the only runtime dep is
# libcrypto, which is ubiquitous.
#
# Login flow:
#   ssh xcesp-tacacs@router
#         → sshd matches `Match User xcesp-tacacs` block in 51-xcesp-tacacs.conf
#         → AuthenticationMethods none → no ssh password
#         → ForceCommand /usr/lib/xcesp/xcesp-tacacs-auth
#         → tool prompts for real username + RADIUS-style password
#         → libcrypto-MD5 TACACS+ Auth ASCII + Authorization
#         → priv-lvl mapped via priv-lvl-map → CliRole
#         → exec /usr/lib/xcesp/xcesp-login with XCESP_ROLE_OVERRIDE +
#           XCESP_AUDIT_USER set
#         → xcesp-login -> xcespcli --role <N>
#
# Cleanup on disable: removes /etc/xcesp/tacacs.conf, the sshd drop-in
# 51-xcesp-tacacs.conf, and the xcesp-tacacs local account.  Also
# strips any leftover 0.2.9 libnss-tacplus state (nsswitch.conf
# `tacplus` entries, /etc/tacplus_nss.conf, the pam_tacplus block in
# /etc/pam.d/sshd) — operators upgrading from 0.2.9 get a clean
# slate.

AAA_CONFIG_FILE="$(dirname "$MANAGED_USERS_FILE")/aaa-config.state"
XCESP_TACACS_USER=xcesp-tacacs
XCESP_TACACS_AUTH_BIN=/usr/lib/xcesp/xcesp-tacacs-auth
XCESP_TACACS_CONF=/etc/xcesp/tacacs.conf
SSHD_TACACS_DROPIN=/etc/ssh/sshd_config.d/51-xcesp-tacacs.conf

# 0.2.16: RADIUS counterparts.  Same pool-account / PAM-permit pattern
# as TACACS, separate drop-in number (52) so both can be installed
# concurrently when aaa.order="local tacacs radius".
XCESP_RADIUS_USER=xcesp-radius
XCESP_RADIUS_AUTH_BIN=/usr/lib/xcesp/xcesp-radius-auth
XCESP_RADIUS_CONF=/etc/xcesp/radius.conf
SSHD_RADIUS_DROPIN=/etc/ssh/sshd_config.d/52-xcesp-radius.conf

# /etc/pam.d/sshd marker block for the xcesp-tacacs pool account.
# AuthenticationMethods none in sshd_config is supposed to skip auth, but
# Fedora's hardened sshd silently ignores it and falls back to password
# auth.  We instead patch the PAM stack so the xcesp-tacacs user's auth
# succeeds without password input — the real TACACS+ authentication then
# happens inside xcesp-tacacs-auth (sshd ForceCommand target).
PAM_SSHD=/etc/pam.d/sshd
PAM_TACACS_BEGIN="# BEGIN xcesp-tacacs-pam"
PAM_TACACS_END="# END xcesp-tacacs-pam"

# 0.2.16: marker block for the xcesp-radius pool account.  Identical
# pattern to the TACACS block above (pam_succeed_if user = xcesp-radius
# with [success=done default=ignore]), different markers so the two
# blocks are independently install/removable.
PAM_RADIUS_BEGIN="# BEGIN xcesp-radius-pam"
PAM_RADIUS_END="# END xcesp-radius-pam"

# 0.2.9-era paths we may need to clean up on upgrade
LEGACY_TACPLUS_NSS_CONF=/etc/tacplus_nss.conf
NSSWITCH_CONF=/etc/nsswitch.conf
LEGACY_TACPLUS_BEGIN="# BEGIN xcesp-tacplus"
LEGACY_TACPLUS_END="# END xcesp-tacplus"

# Prepend a managed block at the TOP of a file (after a leading #%PAM-1.0
# header, if any).  PAM auth stacks are order-sensitive — pam_unix at the
# top would FAIL on our locked xcesp-tacacs account, and `auth required`
# semantics mean the eventual SUCCESS doesn't override that.  So our
# pam_succeed_if must run FIRST and use `[success=done]` to terminate the
# stack with PAM_SUCCESS before any other line runs.
xcesp_pam_prepend_block() {
    local file="$1" begin_marker="$2" end_marker="$3" new_content="$4"

    [ -f "$file" ] || return 0   # nothing to patch if file doesn't exist

    # Strip any pre-existing managed block.
    local stripped
    stripped=$(awk -v b="$begin_marker" -v e="$end_marker" '
        $0 == b { skip = 1; next }
        $0 == e { skip = 0; next }
        !skip   { print }
    ' "$file")

    if [ -z "$new_content" ]; then
        if [ "$stripped" = "$(cat "$file")" ]; then
            return 0   # block wasn't there
        fi
        printf '%s\n' "$stripped" > "$file.tmp" && mv "$file.tmp" "$file"
        log "  $file: removed xcesp PAM block"
        return 0
    fi

    # Insert after a leading #%PAM-1.0 header line if one exists.
    local header tail
    if echo "$stripped" | head -1 | grep -q '^#%PAM-'; then
        header=$(echo "$stripped" | head -1)
        tail=$(echo "$stripped" | tail -n +2)
    else
        header=""
        tail="$stripped"
    fi

    local block
    block=$(printf '%s\n%s\n%s\n' "$begin_marker" "$new_content" "$end_marker")

    local new_full
    if [ -n "$header" ]; then
        new_full=$(printf '%s\n%s\n%s\n' "$header" "$block" "$tail")
    else
        new_full=$(printf '%s\n%s\n' "$block" "$tail")
    fi

    if echo "$new_full" | cmp -s - "$file"; then
        return 0
    fi
    printf '%s\n' "$new_full" > "$file.tmp" && mv "$file.tmp" "$file"
    chmod 0644 "$file" 2>/dev/null || true
    log "  $file: prepended xcesp PAM block"
}

aaa_cfg_get() {
    # Usage: aaa_cfg_get <section> <key> [<default>]
    # Echoes the value (possibly empty) or the default if section/key missing.
    local sect="[$1]" key="$2" default="${3:-}"
    local val
    val=$(awk -v sect="$sect" -v key="$key" '
        $0 == sect    { inS = 1; next }
        /^\[/         { inS = 0 }
        inS && index($0, key " = ") == 1 {
            sub(/^[^=]+= */, "")
            print
            exit
        }
    ' "$AAA_CONFIG_FILE" 2>/dev/null)
    if [ -z "$val" ]; then
        echo "$default"
    else
        echo "$val"
    fi
}

# Idempotent multi-line patching helper: replace the block between
# BEGIN/END markers in a file with new content.  Adds the block at
# end-of-file when no existing markers found.  Removes the block
# entirely when the new content is empty.
xcesp_patch_block() {
    local file="$1" begin_marker="$2" end_marker="$3" new_content="$4"

    if [ ! -f "$file" ]; then
        if [ -n "$new_content" ]; then
            mkdir -p "$(dirname "$file")"
            {
                echo "$begin_marker"
                printf '%s\n' "$new_content"
                echo "$end_marker"
            } > "$file"
            log "  $file: created with xcesp block"
        fi
        return 0
    fi

    # Read existing content sans the managed block.
    local stripped
    stripped=$(awk -v b="$begin_marker" -v e="$end_marker" '
        $0 == b { skip = 1; next }
        $0 == e { skip = 0; next }
        !skip   { print }
    ' "$file")

    if [ -z "$new_content" ]; then
        if echo "$stripped" | cmp -s - "$file"; then
            return 0   # block wasn't there; nothing to do
        fi
        printf '%s\n' "$stripped" > "$file.tmp" && mv "$file.tmp" "$file"
        log "  $file: removed xcesp block"
        return 0
    fi

    local new_full
    new_full=$(printf '%s\n%s\n%s\n%s\n' \
        "$stripped" "$begin_marker" "$new_content" "$end_marker")

    # Skip the write if nothing changed (avoids spurious sshd reloads).
    if echo "$new_full" | cmp -s - "$file"; then
        return 0
    fi
    printf '%s\n' "$new_full" > "$file.tmp" && mv "$file.tmp" "$file"
    log "  $file: updated xcesp block"
}

if [ -f "$AAA_CONFIG_FILE" ]; then
    # Validate magic
    head_line=$(head -1 "$AAA_CONFIG_FILE")
    if [ "$head_line" != "# xcesp aaa-config v1" ]; then
        log "AAA: refusing to process $AAA_CONFIG_FILE — bad magic header"
    else
        aaa_order=$(aaa_cfg_get global order "local")
        tac_present=$(aaa_cfg_get tacacs present "false")
        tac_key=$(aaa_cfg_get tacacs key "")
        tac_timeout=$(aaa_cfg_get tacacs timeout "5")
        tac_servers=$(aaa_cfg_get tacacs servers "")

        tac_enabled=false
        case " $aaa_order " in
            *" tacacs "*)
                if [ "$tac_present" = "true" ] && [ -n "$tac_servers" ] && [ -n "$tac_key" ]; then
                    tac_enabled=true
                fi
                ;;
        esac

        tac_priv_lvl_map=$(aaa_cfg_get tacacs priv-lvl-map "15:1 10:2 5:3 0:4")

        # ----- 0.2.9 legacy cleanup --------------------------------------
        # Always strip the 0.2.9 libnss-tacplus material on every activation.
        # This is idempotent and guarantees an upgrade from 0.2.9 starts from
        # a clean slate before the new pool-account pattern is applied.
        for db in passwd group; do
            if grep -E "^${db}:.*\btacplus\b" "$NSSWITCH_CONF" >/dev/null 2>&1; then
                sed -i -E "s/^(${db}:[^#]*)\btacplus\b[[:space:]]*/\1/" "$NSSWITCH_CONF"
                log "  $NSSWITCH_CONF: stripped legacy 'tacplus' from $db (0.2.9 cleanup)"
            fi
        done
        xcesp_patch_block "$PAM_SSHD" "$LEGACY_TACPLUS_BEGIN" "$LEGACY_TACPLUS_END" ""
        if [ -f "$LEGACY_TACPLUS_NSS_CONF" ]; then
            rm -f "$LEGACY_TACPLUS_NSS_CONF"
            log "  removed legacy $LEGACY_TACPLUS_NSS_CONF (0.2.9 cleanup)"
        fi

        if [ "$tac_enabled" = "true" ]; then
            # Safety probe: the auth tool must be installed before sshd
            # can ForceCommand it.  If install.sh hasn't dropped it yet
            # (mid-upgrade, manual install half-done), skip materialisation
            # rather than create a Match block pointing at a missing exec.
            if [ ! -x "$XCESP_TACACS_AUTH_BIN" ]; then
                log "AAA: TACACS+ requested but $XCESP_TACACS_AUTH_BIN not present — skipping"
                tac_enabled=false
            fi
        fi

        if [ "$tac_enabled" = "true" ]; then
            log "AAA: TACACS+ enabled — order='$aaa_order' priv-lvl-map='$tac_priv_lvl_map'"

            # 1. /etc/xcesp/tacacs.conf — consumed by xcesp-tacacs-auth.
            #    Mode 0640 root:xcesp so the pool account (in xcesp group)
            #    can read but other users cannot see the shared secret.
            mkdir -p /etc/xcesp
            {
                echo "# xcesp tacacs-auth v1 — managed by xcesp-activate, do not edit"
                for sp in $tac_servers; do
                    echo "server $sp"
                done
                echo "key $tac_key"
                echo "timeout $tac_timeout"
                echo "priv-lvl-map $tac_priv_lvl_map"
            } > "$XCESP_TACACS_CONF.tmp"
            chmod 0640 "$XCESP_TACACS_CONF.tmp"
            chown "root:$XCESP_GROUP" "$XCESP_TACACS_CONF.tmp"
            mv "$XCESP_TACACS_CONF.tmp" "$XCESP_TACACS_CONF"
            log "  wrote $XCESP_TACACS_CONF"

            # 2. Local pool account xcesp-tacacs.  System uid, primary
            #    group `xcesp` (so the pool account can read the socket
            #    and the config file via group perms), locked /etc/shadow
            #    (real auth happens in the auth tool, not via sshd PAM
            #    after the pam_succeed_if short-circuit installed above),
            #    shell points at our auth tool.
            #
            #    The home directory `/var/lib/xcesp/xcesp-tacacs` MUST
            #    exist — sshd does `chdir(home)` before exec'ing
            #    ForceCommand and prints a warning to the operator's
            #    terminal if the chdir fails.  We use /var/lib/xcesp/
            #    rather than /home/ because pool accounts aren't real
            #    users and shouldn't live under /home alongside humans.
            XCESP_TACACS_HOME=/var/lib/xcesp/xcesp-tacacs
            if ! id "$XCESP_TACACS_USER" >/dev/null 2>&1; then
                useradd --system --no-create-home \
                        --home-dir "$XCESP_TACACS_HOME" \
                        --shell "$XCESP_TACACS_AUTH_BIN" \
                        -g "$XCESP_GROUP" \
                        --comment "XCESP TACACS+ pool account" \
                        "$XCESP_TACACS_USER"
                passwd -l "$XCESP_TACACS_USER" >/dev/null
                log "  created pool account $XCESP_TACACS_USER (group=$XCESP_GROUP shell=$XCESP_TACACS_AUTH_BIN)"
            else
                # Existing account — fix up shell, group, AND home dir
                # path (older 0.2.10/0.2.11 deployments left it at the
                # useradd default /home/xcesp-tacacs, which never got
                # created, causing the sshd chdir warning).
                current_shell=$(getent passwd "$XCESP_TACACS_USER" | awk -F: '{print $7}')
                if [ "$current_shell" != "$XCESP_TACACS_AUTH_BIN" ]; then
                    usermod -s "$XCESP_TACACS_AUTH_BIN" "$XCESP_TACACS_USER"
                fi
                current_gid=$(id -g "$XCESP_TACACS_USER")
                desired_gid=$(getent group "$XCESP_GROUP" | awk -F: '{print $3}')
                if [ "$current_gid" != "$desired_gid" ]; then
                    usermod -g "$XCESP_GROUP" "$XCESP_TACACS_USER"
                fi
                current_home=$(getent passwd "$XCESP_TACACS_USER" | awk -F: '{print $6}')
                if [ "$current_home" != "$XCESP_TACACS_HOME" ]; then
                    usermod -d "$XCESP_TACACS_HOME" "$XCESP_TACACS_USER"
                    log "  $XCESP_TACACS_USER: home dir → $XCESP_TACACS_HOME"
                fi
            fi
            # Always ensure the home dir actually exists on disk.
            if [ ! -d "$XCESP_TACACS_HOME" ]; then
                install -d -o "$XCESP_TACACS_USER" -g "$XCESP_GROUP" -m 0700 \
                    "$XCESP_TACACS_HOME"
                log "  created $XCESP_TACACS_HOME"
            fi

            # 3. PAM patch — let xcesp-tacacs's auth succeed without
            #    password input.  We prepend a pam_succeed_if line at the
            #    top of /etc/pam.d/sshd: when the user is xcesp-tacacs,
            #    [success=done] terminates the PAM auth stack with
            #    PAM_SUCCESS; for any other user, [default=ignore] skips
            #    our line and the normal auth chain (pam_unix, etc.) runs
            #    unchanged.  This is the same "shared pool account" pattern
            #    Cumulus Linux and pfSense use for RADIUS/TACACS gates.
            #
            #    `quiet_success` keeps /var/log/secure from logging the
            #    bypass on every connection — the auth tool itself does
            #    the audit-relevant logging via LOG_AUTHPRIV.
            pam_block="auth [success=done default=ignore] pam_succeed_if.so user = $XCESP_TACACS_USER quiet_success"
            xcesp_pam_prepend_block "$PAM_SSHD" "$PAM_TACACS_BEGIN" "$PAM_TACACS_END" "$pam_block"

            # 4. /etc/ssh/sshd_config.d/51-xcesp-tacacs.conf — Match User
            #    block.  AuthenticationMethods=password + PermitEmptyPasswords
            #    yes means sshd prompts for a password but accepts ANY
            #    input (including just Enter) — the PAM stack short-circuits
            #    via the pam_succeed_if line we just installed.  ForceCommand
            #    then drops the operator into xcesp-tacacs-auth which
            #    performs the real TACACS+ auth.
            mkdir -p /etc/ssh/sshd_config.d
            cat > "$SSHD_TACACS_DROPIN.tmp" <<SSHEOF
# BEGIN xcesp-tacacs — managed by xcesp-activate, do not edit
#
# Shared pool account for TACACS+-authenticated users.  Users ssh as
# \`$XCESP_TACACS_USER@router\`; sshd's password prompt appears but the
# PAM stack (see /etc/pam.d/sshd's xcesp-tacacs-pam block) short-circuits
# to PAM_SUCCESS for this specific user.  Press Enter (or type any
# garbage) to get past the prompt.  ForceCommand then drops into
# xcesp-tacacs-auth, which does the REAL TACACS+ authentication against
# the configured server.  A FAIL from the TACACS server exits the tool
# with status 1, dropping the operator out of ssh — no shell access
# leaked.

Match User $XCESP_TACACS_USER
    PasswordAuthentication yes
    PermitEmptyPasswords yes
    PubkeyAuthentication no
    KbdInteractiveAuthentication no
    AuthenticationMethods password
    PermitTTY yes
    X11Forwarding no
    AllowTcpForwarding no
    PermitTunnel no
    ForceCommand $XCESP_TACACS_AUTH_BIN
# END xcesp-tacacs
SSHEOF
            chmod 0644 "$SSHD_TACACS_DROPIN.tmp"
            chown root:root "$SSHD_TACACS_DROPIN.tmp"
            if ! cmp -s "$SSHD_TACACS_DROPIN.tmp" "$SSHD_TACACS_DROPIN" 2>/dev/null; then
                mv "$SSHD_TACACS_DROPIN.tmp" "$SSHD_TACACS_DROPIN"
                log "  wrote $SSHD_TACACS_DROPIN"
                systemctl reload sshd 2>/dev/null || systemctl reload ssh 2>/dev/null || true
            else
                rm -f "$SSHD_TACACS_DROPIN.tmp"
            fi
        else
            log "AAA: TACACS+ disabled — tearing down"

            if [ -f "$SSHD_TACACS_DROPIN" ]; then
                rm -f "$SSHD_TACACS_DROPIN"
                log "  removed $SSHD_TACACS_DROPIN"
                systemctl reload sshd 2>/dev/null || systemctl reload ssh 2>/dev/null || true
            fi
            # Strip the PAM block too — never leave a permit-without-password
            # entry behind for an account that no longer exists.
            xcesp_pam_prepend_block "$PAM_SSHD" "$PAM_TACACS_BEGIN" "$PAM_TACACS_END" ""
            if id "$XCESP_TACACS_USER" >/dev/null 2>&1; then
                userdel "$XCESP_TACACS_USER" 2>/dev/null || true
                log "  removed pool account $XCESP_TACACS_USER"
            fi
            if [ -f "$XCESP_TACACS_CONF" ]; then
                rm -f "$XCESP_TACACS_CONF"
                log "  removed $XCESP_TACACS_CONF"
            fi
        fi

        # =====================================================================
        # RADIUS materialisation (0.2.16) — mirrors the TACACS block above.
        # =====================================================================
        rad_present=$(aaa_cfg_get radius present "false")
        rad_key=$(aaa_cfg_get radius key "")
        rad_timeout=$(aaa_cfg_get radius timeout "3")
        rad_servers=$(aaa_cfg_get radius servers "")
        rad_svc_map=$(aaa_cfg_get radius service-type-map "6:1 7:2 1:3")

        rad_enabled=false
        case " $aaa_order " in
            *" radius "*)
                if [ "$rad_present" = "true" ] && [ -n "$rad_servers" ] && [ -n "$rad_key" ]; then
                    rad_enabled=true
                fi
                ;;
        esac

        if [ "$rad_enabled" = "true" ]; then
            if [ ! -x "$XCESP_RADIUS_AUTH_BIN" ]; then
                log "AAA: RADIUS requested but $XCESP_RADIUS_AUTH_BIN not present — skipping"
                rad_enabled=false
            fi
        fi

        if [ "$rad_enabled" = "true" ]; then
            log "AAA: RADIUS enabled — order='$aaa_order' service-type-map='$rad_svc_map'"

            # 1. /etc/xcesp/radius.conf — consumed by xcesp-radius-auth.
            #    Same mode/owner pattern as the TACACS conf (0640 root:xcesp)
            #    so the pool account (in xcesp group) can read but other
            #    users cannot see the shared secret.
            mkdir -p /etc/xcesp
            {
                echo "# xcesp radius-auth v1 — managed by xcesp-activate, do not edit"
                for sp in $rad_servers; do
                    echo "server $sp"
                done
                echo "key $rad_key"
                echo "timeout $rad_timeout"
                echo "service-type-map $rad_svc_map"
            } > "$XCESP_RADIUS_CONF.tmp"
            chmod 0640 "$XCESP_RADIUS_CONF.tmp"
            chown "root:$XCESP_GROUP" "$XCESP_RADIUS_CONF.tmp"
            mv "$XCESP_RADIUS_CONF.tmp" "$XCESP_RADIUS_CONF"
            log "  wrote $XCESP_RADIUS_CONF"

            # 2. Local pool account xcesp-radius.  Same configuration as
            #    xcesp-tacacs: system uid, primary group `xcesp`, locked
            #    /etc/shadow, shell is the auth tool, home under
            #    /var/lib/xcesp/ (sshd chdirs here before ForceCommand).
            XCESP_RADIUS_HOME=/var/lib/xcesp/xcesp-radius
            if ! id "$XCESP_RADIUS_USER" >/dev/null 2>&1; then
                useradd --system --no-create-home \
                        --home-dir "$XCESP_RADIUS_HOME" \
                        --shell "$XCESP_RADIUS_AUTH_BIN" \
                        -g "$XCESP_GROUP" \
                        --comment "XCESP RADIUS pool account" \
                        "$XCESP_RADIUS_USER"
                passwd -l "$XCESP_RADIUS_USER" >/dev/null
                log "  created pool account $XCESP_RADIUS_USER (group=$XCESP_GROUP shell=$XCESP_RADIUS_AUTH_BIN)"
            else
                current_shell=$(getent passwd "$XCESP_RADIUS_USER" | awk -F: '{print $7}')
                if [ "$current_shell" != "$XCESP_RADIUS_AUTH_BIN" ]; then
                    usermod -s "$XCESP_RADIUS_AUTH_BIN" "$XCESP_RADIUS_USER"
                fi
                current_gid=$(id -g "$XCESP_RADIUS_USER")
                desired_gid=$(getent group "$XCESP_GROUP" | awk -F: '{print $3}')
                if [ "$current_gid" != "$desired_gid" ]; then
                    usermod -g "$XCESP_GROUP" "$XCESP_RADIUS_USER"
                fi
                current_home=$(getent passwd "$XCESP_RADIUS_USER" | awk -F: '{print $6}')
                if [ "$current_home" != "$XCESP_RADIUS_HOME" ]; then
                    usermod -d "$XCESP_RADIUS_HOME" "$XCESP_RADIUS_USER"
                    log "  $XCESP_RADIUS_USER: home dir → $XCESP_RADIUS_HOME"
                fi
            fi
            if [ ! -d "$XCESP_RADIUS_HOME" ]; then
                install -d -o "$XCESP_RADIUS_USER" -g "$XCESP_GROUP" -m 0700 \
                    "$XCESP_RADIUS_HOME"
                log "  created $XCESP_RADIUS_HOME"
            fi

            # 3. PAM permit hack for the xcesp-radius user — same shape as
            #    the TACACS block; independent markers so removing one
            #    does not disturb the other.
            pam_block_r="auth [success=done default=ignore] pam_succeed_if.so user = $XCESP_RADIUS_USER quiet_success"
            xcesp_pam_prepend_block "$PAM_SSHD" "$PAM_RADIUS_BEGIN" "$PAM_RADIUS_END" "$pam_block_r"

            # 4. /etc/ssh/sshd_config.d/52-xcesp-radius.conf — Match User
            #    block.  ForceCommand drops the operator into
            #    xcesp-radius-auth which performs the real RADIUS
            #    authentication.
            mkdir -p /etc/ssh/sshd_config.d
            cat > "$SSHD_RADIUS_DROPIN.tmp" <<SSHEOFR
# BEGIN xcesp-radius — managed by xcesp-activate, do not edit
#
# Shared pool account for RADIUS-authenticated users.  Users ssh as
# \`$XCESP_RADIUS_USER@router\`; sshd's password prompt appears but the
# PAM stack (see /etc/pam.d/sshd's xcesp-radius-pam block) short-circuits
# to PAM_SUCCESS for this specific user.  Press Enter (or type any
# garbage) to get past the prompt.  ForceCommand then drops into
# xcesp-radius-auth, which does the REAL RADIUS authentication against
# the configured server.  An Access-Reject from the RADIUS server exits
# the tool with status 1, dropping the operator out of ssh — no shell
# access leaked.

Match User $XCESP_RADIUS_USER
    PasswordAuthentication yes
    PermitEmptyPasswords yes
    PubkeyAuthentication no
    KbdInteractiveAuthentication no
    AuthenticationMethods password
    PermitTTY yes
    X11Forwarding no
    AllowTcpForwarding no
    PermitTunnel no
    ForceCommand $XCESP_RADIUS_AUTH_BIN
# END xcesp-radius
SSHEOFR
            chmod 0644 "$SSHD_RADIUS_DROPIN.tmp"
            chown root:root "$SSHD_RADIUS_DROPIN.tmp"
            if ! cmp -s "$SSHD_RADIUS_DROPIN.tmp" "$SSHD_RADIUS_DROPIN" 2>/dev/null; then
                mv "$SSHD_RADIUS_DROPIN.tmp" "$SSHD_RADIUS_DROPIN"
                log "  wrote $SSHD_RADIUS_DROPIN"
                systemctl reload sshd 2>/dev/null || systemctl reload ssh 2>/dev/null || true
            else
                rm -f "$SSHD_RADIUS_DROPIN.tmp"
            fi
        else
            log "AAA: RADIUS disabled — tearing down"

            if [ -f "$SSHD_RADIUS_DROPIN" ]; then
                rm -f "$SSHD_RADIUS_DROPIN"
                log "  removed $SSHD_RADIUS_DROPIN"
                systemctl reload sshd 2>/dev/null || systemctl reload ssh 2>/dev/null || true
            fi
            xcesp_pam_prepend_block "$PAM_SSHD" "$PAM_RADIUS_BEGIN" "$PAM_RADIUS_END" ""
            if id "$XCESP_RADIUS_USER" >/dev/null 2>&1; then
                userdel "$XCESP_RADIUS_USER" 2>/dev/null || true
                log "  removed pool account $XCESP_RADIUS_USER"
            fi
            if [ -f "$XCESP_RADIUS_CONF" ]; then
                rm -f "$XCESP_RADIUS_CONF"
                log "  removed $XCESP_RADIUS_CONF"
            fi
        fi

        # =====================================================================
        # SNMP AgentX materialisation (0.2.19+; revised in 0.2.21)
        # =====================================================================
        #
        # When the operator sets `management snmp enabled true`, install two
        # managed pieces so xcespserver (a subagent) can connect to the
        # master snmpd:
        #
        #   1. A marker block in /etc/snmp/snmpd.conf with `master agentx`
        #      + `agentXSocket`.  Fedora's stock snmpd does NOT auto-include
        #      /etc/snmp/snmpd.conf.d/ (Debian's does) — the 0.2.20 drop-in
        #      approach therefore worked on Debian but was silently ignored
        #      on Fedora, leaving snmpd without AgentX support.
        #
        #   2. A systemd drop-in for snmpd.service that fixes up the AgentX
        #      socket's group + perms post-start.  Fedora's net-snmp 5.9.4
        #      rejects the `agentXPerms 0660 0660 root xcesp` form with
        #      "Can't identify user (root).", and falls back to creating
        #      the socket as root:root mode 0755 — unreachable from the
        #      xcesp uid.  An ExecStartPost chgrp + chmod fixes this
        #      cleanly without needing snmpd config tricks.
        #
        # Teardown: strip the marker block, remove the drop-in, daemon-
        # reload, restart snmpd.  Also clean up the legacy 0.2.20 conf.d
        # drop-in if it exists.

        snmp_present=$(aaa_cfg_get snmp present "false")
        snmp_enabled=$(aaa_cfg_get snmp enabled "false")

        SNMPD_MAIN_CONF=/etc/snmp/snmpd.conf
        SNMPD_MARKER_BEGIN="# BEGIN xcesp-snmp"
        SNMPD_MARKER_END="# END xcesp-snmp"
        SNMPD_SYSTEMD_DROPIN=/etc/systemd/system/snmpd.service.d/xcesp.conf
        SNMPD_LEGACY_CONFD=/etc/snmp/snmpd.conf.d/xcesp.conf   # 0.2.20 leftover

        # Always strip the legacy 0.2.20 conf.d drop-in on every activation.
        # Idempotent: guarantees an upgrade from 0.2.20 leaves a clean
        # slate before the new marker-block pattern goes in.
        if [ -f "$SNMPD_LEGACY_CONFD" ]; then
            rm -f "$SNMPD_LEGACY_CONFD"
            log "  removed legacy $SNMPD_LEGACY_CONFD (0.2.20 cleanup)"
        fi

        if [ "$snmp_present" = "true" ] && [ "$snmp_enabled" = "true" ]; then
            log "AAA: SNMP enabled — patching $SNMPD_MAIN_CONF + installing systemd drop-in"

            # 1. Marker block in /etc/snmp/snmpd.conf.  AgentX glue
            #    + (0.2.x) one trap2sink/trapsink line per enabled
            #    trap-target instance.  Targets serialised in
            #    aaa-config.state under [snmp] with .count + indexed
            #    keys; we iterate them here and emit the matching
            #    snmpd directives.  Communities arrive plaintext via
            #    decryptConfigSecrets ahead of aaa_cfg_get; do NOT
            #    log them.
            snmpd_block="master agentx"
            snmpd_block="${snmpd_block}
agentXSocket /var/agentx/master"

            # 0.3.1 — view definitions FIRST so any rocommunity /
            # rwcommunity line below that references them via `-V
            # VIEW` parses cleanly.  ManagementConfig auto-inserts a
            # default xcespview {included = .1} when the operator
            # didn't configure any views, so the count is always
            # >= 1 when SNMP is enabled.
            view_count=$(aaa_cfg_get snmp view.count "0")
            if [ -n "$view_count" ] && [ "$view_count" != "0" ]; then
                i=1
                view_emitted=0
                while [ "$i" -le "$view_count" ]; do
                    v_label=$(aaa_cfg_get snmp "view.${i}.label" "")
                    v_inc=$(aaa_cfg_get snmp "view.${i}.included" "")
                    v_exc=$(aaa_cfg_get snmp "view.${i}.excluded" "")
                    if [ -n "$v_label" ] && [ -n "$v_inc" ]; then
                        snmpd_block="${snmpd_block}
view ${v_label} included ${v_inc}"
                        if [ -n "$v_exc" ]; then
                            snmpd_block="${snmpd_block}
view ${v_label} excluded ${v_exc}"
                        fi
                        view_emitted=$((view_emitted + 1))
                    fi
                    i=$((i + 1))
                done
                if [ "$view_emitted" -gt 0 ]; then
                    log "  views configured: $view_emitted"
                fi
            fi

            # 0.3.1 — SNMPv2c community-string ACLs.  Each enabled
            # entry becomes one `rocommunity` / `rwcommunity` line.
            # `-V <view>` is required: snmpd parses a bare 4th
            # token as an OID and errors with `bad SUBTREE object
            # id`.  Community values arrive plaintext via
            # decryptConfigSecrets; never log them.
            v2c_count=$(aaa_cfg_get snmp v2c-community.count "0")
            if [ -n "$v2c_count" ] && [ "$v2c_count" != "0" ]; then
                i=1
                v2c_emitted=0
                while [ "$i" -le "$v2c_count" ]; do
                    c_enabled=$(aaa_cfg_get snmp "v2c-community.${i}.enabled" "true")
                    if [ "$c_enabled" = "true" ]; then
                        c_community=$(aaa_cfg_get snmp "v2c-community.${i}.community" "")
                        c_access=$(aaa_cfg_get snmp "v2c-community.${i}.access" "ro")
                        c_source=$(aaa_cfg_get snmp "v2c-community.${i}.source" "default")
                        c_view=$(aaa_cfg_get snmp "v2c-community.${i}.view" "xcespview")
                        if [ -n "$c_community" ] && [ -n "$c_view" ]; then
                            case "$c_access" in
                                rw) directive="rwcommunity" ;;
                                *)  directive="rocommunity" ;;
                            esac
                            snmpd_block="${snmpd_block}
${directive} ${c_community} ${c_source} -V ${c_view}"
                            v2c_emitted=$((v2c_emitted + 1))
                        fi
                    fi
                    i=$((i + 1))
                done
                if [ "$v2c_emitted" -gt 0 ]; then
                    log "  v2c communities configured: $v2c_emitted enabled"
                fi
            fi

            # 0.3.3 — SNMPv3 USM users.  Two-phase materialisation:
            #
            # Phase A (this loop): render rouser/rwuser lines into
            # the marker block in /etc/snmp/snmpd.conf, alongside
            # the view + community lines.  Same `-V VIEW` literal
            # syntax as v2c-community (a bare view name parses as
            # an OID and errors with `bad SUBTREE object id`).
            # Security level is derived from password presence:
            #   no auth-password               -> noauth
            #   auth-password only             -> auth
            #   both auth-password + priv-pw   -> priv
            #
            # Phase B (createUser dance) happens AFTER the marker
            # block is patched and before the snmpd restart — see
            # below.  Reason: net-snmp's createUser is consume-on-
            # start, so we must (1) stop snmpd, (2) write fresh
            # createUser lines into /var/lib/net-snmp/snmpd.conf,
            # (3) start snmpd.  Idempotency via hash sidecar at
            # /var/lib/xcesp/snmp-v3-users.state — when the desired
            # tuple-hash matches the previous activation, Phase B
            # is skipped entirely and snmpd only needs a reload (if
            # the marker block changed) or nothing.
            v3_count=$(aaa_cfg_get snmp v3-user.count "0")
            if [ -n "$v3_count" ] && [ "$v3_count" != "0" ]; then
                i=1
                v3_emitted=0
                while [ "$i" -le "$v3_count" ]; do
                    u_enabled=$(aaa_cfg_get snmp "v3-user.${i}.enabled" "true")
                    if [ "$u_enabled" = "true" ]; then
                        u_name=$(aaa_cfg_get snmp "v3-user.${i}.name" "")
                        u_authpw=$(aaa_cfg_get snmp "v3-user.${i}.auth-password" "")
                        u_privpw=$(aaa_cfg_get snmp "v3-user.${i}.priv-password" "")
                        u_access=$(aaa_cfg_get snmp "v3-user.${i}.access" "ro")
                        u_view=$(aaa_cfg_get snmp "v3-user.${i}.view" "xcespview")
                        if [ -n "$u_name" ] && [ -n "$u_view" ]; then
                            case "$u_access" in
                                rw) directive="rwuser" ;;
                                *)  directive="rouser" ;;
                            esac
                            if [ -n "$u_authpw" ] && [ -n "$u_privpw" ]; then
                                u_level="priv"
                            elif [ -n "$u_authpw" ]; then
                                u_level="auth"
                            else
                                u_level="noauth"
                            fi
                            snmpd_block="${snmpd_block}
${directive} ${u_name} ${u_level} -V ${u_view}"
                            v3_emitted=$((v3_emitted + 1))
                        fi
                    fi
                    i=$((i + 1))
                done
                if [ "$v3_emitted" -gt 0 ]; then
                    log "  v3 users configured: $v3_emitted enabled"
                fi
            fi

            trap_count=$(aaa_cfg_get snmp trap-target.count "0")
            if [ -n "$trap_count" ] && [ "$trap_count" != "0" ]; then
                i=1
                trap_emitted=0
                while [ "$i" -le "$trap_count" ]; do
                    t_enabled=$(aaa_cfg_get snmp "trap-target.${i}.enabled" "true")
                    if [ "$t_enabled" = "true" ]; then
                        t_host=$(aaa_cfg_get snmp "trap-target.${i}.host" "")
                        t_port=$(aaa_cfg_get snmp "trap-target.${i}.port" "162")
                        t_comm=$(aaa_cfg_get snmp "trap-target.${i}.community" "public")
                        t_ver=$(aaa_cfg_get snmp "trap-target.${i}.version" "v2c")
                        if [ -n "$t_host" ]; then
                            case "$t_ver" in
                                v1) directive="trapsink"   ;;
                                *)  directive="trap2sink"  ;;
                            esac
                            snmpd_block="${snmpd_block}
${directive} ${t_host}:${t_port} ${t_comm}"
                            trap_emitted=$((trap_emitted + 1))
                        fi
                    fi
                    i=$((i + 1))
                done
                if [ "$trap_emitted" -gt 0 ]; then
                    log "  trap targets configured: $trap_emitted enabled"
                fi
            fi
            need_snmpd_reload=false
            if [ -f "$SNMPD_MAIN_CONF" ]; then
                pre=$(sha256sum "$SNMPD_MAIN_CONF" 2>/dev/null | awk '{print $1}')
                xcesp_patch_block "$SNMPD_MAIN_CONF" \
                    "$SNMPD_MARKER_BEGIN" "$SNMPD_MARKER_END" "$snmpd_block"
                post=$(sha256sum "$SNMPD_MAIN_CONF" 2>/dev/null | awk '{print $1}')
                [ "$pre" != "$post" ] && need_snmpd_reload=true
            else
                log "  $SNMPD_MAIN_CONF not present — skipping marker block (snmpd not installed?)"
            fi

            # 2. Systemd drop-in that fixes the socket's group + perms after
            # snmpd creates it.  agentXPerms on Fedora's snmpd is broken
            # (see comment above), so we work around with ExecStartPost.
            install -d -o root -g root -m 0755 "$(dirname "$SNMPD_SYSTEMD_DROPIN")"
            cat > "$SNMPD_SYSTEMD_DROPIN.tmp" <<'SYSDDROPIN'
# Managed by xcesp-activate.  Fixes /var/agentx/master perms so the
# xcespserver subagent (uid xcesp) can connect to the AgentX socket
# that snmpd creates as root:root mode 0755 by default.
[Service]
ExecStartPost=/bin/sh -c 'chgrp xcesp /var/agentx/master 2>/dev/null; chmod 0660 /var/agentx/master 2>/dev/null; true'
SYSDDROPIN
            chmod 0644 "$SNMPD_SYSTEMD_DROPIN.tmp"
            chown root:root "$SNMPD_SYSTEMD_DROPIN.tmp"
            need_daemon_reload=false
            if ! cmp -s "$SNMPD_SYSTEMD_DROPIN.tmp" "$SNMPD_SYSTEMD_DROPIN" 2>/dev/null; then
                mv "$SNMPD_SYSTEMD_DROPIN.tmp" "$SNMPD_SYSTEMD_DROPIN"
                log "  wrote $SNMPD_SYSTEMD_DROPIN"
                need_daemon_reload=true
                need_snmpd_reload=true
            else
                rm -f "$SNMPD_SYSTEMD_DROPIN.tmp"
            fi

            if [ "$need_daemon_reload" = "true" ]; then
                systemctl daemon-reload 2>/dev/null || true
            fi

            # 0.3.3 Phase B — SNMPv3 USM users idempotency dance.
            #
            # net-snmp's createUser is consume-on-start: the line in
            # /var/lib/net-snmp/snmpd.conf is parsed only when snmpd
            # boots, and snmpd then replaces it with a hashed
            # `usmUser` entry on shutdown.  A running snmpd holds the
            # file open and ignores any createUser appended underneath
            # it.  So:
            #
            #   1. Hash the desired (name, protocols, passwords)
            #      tuple of every ENABLED v3-user, compare against
            #      /var/lib/xcesp/snmp-v3-users.state.
            #   2. On mismatch (= operator added/changed/removed at
            #      least one user): stop snmpd, append fresh
            #      createUser lines, save new hash, force restart.
            #   3. On match: skip the dance entirely — the marker
            #      block may still need a reload (handled below).
            #
            # The state-file path lives under /var/lib/xcesp/ which is
            # mode 2775 root:xcesp; the v3-users.state file is mode
            # 0600 root:xcesp because the hash itself isn't sensitive
            # but consistent perms with the AAA state file is the
            # path of least surprise.
            V3_STATE=/var/lib/xcesp/snmp-v3-users.state

            # 0.3.4 — detect snmpd's persistent-state file cross-distro.
            # Fedora's net-snmp build uses /var/lib/net-snmp/snmpd.conf
            # (compile default).  Debian's snmpd package uses
            # /var/lib/snmp/snmpd.conf (owned by Debian-snmp:Debian-snmp,
            # the snmpd runtime user).  Writing createUser lines to the
            # wrong path means snmpd never consumes them on Debian.
            #
            # Probe in this order:
            #   1. an existing snmpd.conf file (live state)
            #   2. an existing directory (snmpd installed but stateless)
            #   3. distro fallback by /etc/os-release id_like
            NET_SNMP_PERSIST=""
            for cand in /var/lib/snmp/snmpd.conf /var/lib/net-snmp/snmpd.conf; do
                if [ -f "$cand" ]; then
                    NET_SNMP_PERSIST="$cand"
                    break
                fi
            done
            if [ -z "$NET_SNMP_PERSIST" ]; then
                for d in /var/lib/snmp /var/lib/net-snmp; do
                    if [ -d "$d" ]; then
                        NET_SNMP_PERSIST="$d/snmpd.conf"
                        break
                    fi
                done
            fi
            if [ -z "$NET_SNMP_PERSIST" ]; then
                if grep -qi 'ID_LIKE=.*debian\|^ID=debian\|^ID=ubuntu' /etc/os-release 2>/dev/null; then
                    NET_SNMP_PERSIST=/var/lib/snmp/snmpd.conf
                else
                    NET_SNMP_PERSIST=/var/lib/net-snmp/snmpd.conf
                fi
            fi
            log "  net-snmp persistent file: $NET_SNMP_PERSIST"

            # Capture the runtime ownership snmpd expects on this file
            # (Debian: Debian-snmp:Debian-snmp; Fedora: root:root).  If
            # the file already exists we keep its current owner; if it
            # has to be created we mirror the parent directory's owner
            # (which is what each distro's snmpd-package install
            # configured).
            if [ -f "$NET_SNMP_PERSIST" ]; then
                NET_SNMP_OWN=$(stat -c '%U:%G' "$NET_SNMP_PERSIST" 2>/dev/null || echo "root:root")
            else
                NET_SNMP_OWN=$(stat -c '%U:%G' "$(dirname "$NET_SNMP_PERSIST")" 2>/dev/null || echo "root:root")
            fi

            v3_desired_hash=""
            if [ -n "$v3_count" ] && [ "$v3_count" != "0" ]; then
                v3_desired_input=""
                i=1
                while [ "$i" -le "$v3_count" ]; do
                    u_enabled=$(aaa_cfg_get snmp "v3-user.${i}.enabled" "true")
                    if [ "$u_enabled" = "true" ]; then
                        u_name=$(aaa_cfg_get snmp "v3-user.${i}.name" "")
                        u_authp=$(aaa_cfg_get snmp "v3-user.${i}.auth-protocol" "SHA")
                        u_authpw=$(aaa_cfg_get snmp "v3-user.${i}.auth-password" "")
                        u_privp=$(aaa_cfg_get snmp "v3-user.${i}.priv-protocol" "AES")
                        u_privpw=$(aaa_cfg_get snmp "v3-user.${i}.priv-password" "")
                        v3_desired_input="${v3_desired_input}${u_name}|${u_authp}|${u_authpw}|${u_privp}|${u_privpw}
"
                    fi
                    i=$((i + 1))
                done
                v3_desired_hash=$(printf "%s" "$v3_desired_input" | sha256sum | awk '{print $1}')
            else
                v3_desired_hash="empty"
            fi
            v3_actual_hash=$(cat "$V3_STATE" 2>/dev/null || echo "")

            if [ "$v3_desired_hash" != "$v3_actual_hash" ]; then
                log "  v3-user set changed (hash $v3_actual_hash -> $v3_desired_hash) — running createUser dance"
                systemctl stop snmpd 2>/dev/null || true
                # Ensure the persistent directory exists with the right
                # ownership for snmpd's runtime user.  install -d is a
                # no-op when the directory already exists with the
                # expected attrs.
                NET_SNMP_DIR=$(dirname "$NET_SNMP_PERSIST")
                NET_SNMP_DIR_OWN_USER=${NET_SNMP_OWN%:*}
                NET_SNMP_DIR_OWN_GROUP=${NET_SNMP_OWN#*:}
                if [ ! -d "$NET_SNMP_DIR" ]; then
                    install -d -o "$NET_SNMP_DIR_OWN_USER" -g "$NET_SNMP_DIR_OWN_GROUP" -m 0755 "$NET_SNMP_DIR"
                fi
                # Strip any prior xcesp-managed createUser block.
                if [ -f "$NET_SNMP_PERSIST" ]; then
                    sed -i '/^# BEGIN xcesp-v3-users/,/^# END xcesp-v3-users/d' "$NET_SNMP_PERSIST"
                fi
                if [ -n "$v3_count" ] && [ "$v3_count" != "0" ]; then
                    touch "$NET_SNMP_PERSIST" 2>/dev/null
                    chmod 0600 "$NET_SNMP_PERSIST" 2>/dev/null
                    chown "$NET_SNMP_OWN" "$NET_SNMP_PERSIST" 2>/dev/null
                    {
                        echo "# BEGIN xcesp-v3-users (managed by xcesp-activate; do not edit)"
                        i=1
                        while [ "$i" -le "$v3_count" ]; do
                            u_enabled=$(aaa_cfg_get snmp "v3-user.${i}.enabled" "true")
                            if [ "$u_enabled" = "true" ]; then
                                u_name=$(aaa_cfg_get snmp "v3-user.${i}.name" "")
                                u_authp=$(aaa_cfg_get snmp "v3-user.${i}.auth-protocol" "SHA")
                                u_authpw=$(aaa_cfg_get snmp "v3-user.${i}.auth-password" "")
                                u_privp=$(aaa_cfg_get snmp "v3-user.${i}.priv-protocol" "AES")
                                u_privpw=$(aaa_cfg_get snmp "v3-user.${i}.priv-password" "")
                                if [ -n "$u_name" ]; then
                                    if [ -n "$u_authpw" ] && [ -n "$u_privpw" ]; then
                                        echo "createUser ${u_name} ${u_authp} \"${u_authpw}\" ${u_privp} \"${u_privpw}\""
                                    elif [ -n "$u_authpw" ]; then
                                        echo "createUser ${u_name} ${u_authp} \"${u_authpw}\""
                                    else
                                        echo "createUser ${u_name}"
                                    fi
                                fi
                            fi
                            i=$((i + 1))
                        done
                        echo "# END xcesp-v3-users"
                    } >> "$NET_SNMP_PERSIST"
                fi
                install -d -o root -g xcesp -m 2775 /var/lib/xcesp 2>/dev/null
                printf "%s\n" "$v3_desired_hash" > "$V3_STATE.tmp"
                chmod 0600 "$V3_STATE.tmp" 2>/dev/null
                chown root:xcesp "$V3_STATE.tmp" 2>/dev/null
                mv "$V3_STATE.tmp" "$V3_STATE"
                need_snmpd_reload=true   # force the start path below
            fi

            if [ "$need_snmpd_reload" = "true" ]; then
                # Restart (not reload) so ExecStartPost and the new marker
                # block both take effect, AND the socket is recreated under
                # the new perms.
                systemctl restart snmpd 2>/dev/null || true
            fi
        else
            log "AAA: SNMP disabled — tearing down snmpd integration"

            need_snmpd_reload=false
            need_daemon_reload=false
            if [ -f "$SNMPD_MAIN_CONF" ]; then
                pre=$(sha256sum "$SNMPD_MAIN_CONF" 2>/dev/null | awk '{print $1}')
                xcesp_patch_block "$SNMPD_MAIN_CONF" \
                    "$SNMPD_MARKER_BEGIN" "$SNMPD_MARKER_END" ""
                post=$(sha256sum "$SNMPD_MAIN_CONF" 2>/dev/null | awk '{print $1}')
                [ "$pre" != "$post" ] && need_snmpd_reload=true
            fi
            if [ -f "$SNMPD_SYSTEMD_DROPIN" ]; then
                rm -f "$SNMPD_SYSTEMD_DROPIN"
                log "  removed $SNMPD_SYSTEMD_DROPIN"
                need_daemon_reload=true
                need_snmpd_reload=true
            fi
            # 0.3.3 — strip xcesp-managed createUser block from
            # snmpd's persistent-state file when SNMP is disabled,
            # and clear the hash sidecar so a future re-enable runs
            # Phase B fresh.
            #
            # 0.3.4 — probe both Debian (/var/lib/snmp) and Fedora
            # (/var/lib/net-snmp) locations so teardown finds and
            # strips whichever one we wrote to.  Strip from both if
            # both happen to have our block (defensive — shouldn't
            # normally happen but cheap to handle).
            V3_STATE=/var/lib/xcesp/snmp-v3-users.state
            stripped_any=false
            for persist in /var/lib/snmp/snmpd.conf /var/lib/net-snmp/snmpd.conf; do
                if [ -f "$persist" ] && grep -q "^# BEGIN xcesp-v3-users" "$persist" 2>/dev/null; then
                    if [ "$stripped_any" = "false" ]; then
                        systemctl stop snmpd 2>/dev/null || true
                    fi
                    sed -i '/^# BEGIN xcesp-v3-users/,/^# END xcesp-v3-users/d' "$persist"
                    log "  stripped xcesp-v3-users block from $persist"
                    stripped_any=true
                    need_snmpd_reload=true
                fi
            done
            if [ -f "$V3_STATE" ]; then
                rm -f "$V3_STATE"
                log "  removed $V3_STATE"
            fi
            if [ "$need_daemon_reload" = "true" ]; then
                systemctl daemon-reload 2>/dev/null || true
            fi
            if [ "$need_snmpd_reload" = "true" ]; then
                systemctl restart snmpd 2>/dev/null || true
            fi
        fi
    fi
else
    log "AAA: $AAA_CONFIG_FILE not present — TACACS+/RADIUS/SNMP materialisation skipped"
fi

# ---------------------------------------------------------------------------
# 0.3.0 — fleet.key permission sanity
# ---------------------------------------------------------------------------
#
# When the operator opts into cross-machine secret portability by
# setting `[SECRETS] KEY_SOURCE = file:/etc/xcesp/fleet.key,machine-id`
# in xcespserver.ini, they MUST provision /etc/xcesp/fleet.key
# out-of-band (Ansible vault, ZTP, manual scp).  xcesp-activate does
# NOT create or sync the file — only enforces minimum-correct
# permissions if it's present, and logs one line so the operator can
# see in the journal whether the file is present and usable.
#
# Required: mode 0640 owner root:xcesp (xcespserver runs as the
# xcesp uid; group-read is sufficient).  Empty files would
# deterministically derive a constant key — keySourceUsable() rejects
# zero-byte sources but we also warn here.
FLEET_KEY=/etc/xcesp/fleet.key
if [ -f "$FLEET_KEY" ]; then
    if [ ! -s "$FLEET_KEY" ]; then
        log "  WARNING $FLEET_KEY is empty — SecretEncryptor will skip it"
    fi
    if [ "$(stat -c '%a' "$FLEET_KEY" 2>/dev/null)" != "640" ]; then
        if chmod 0640 "$FLEET_KEY" 2>/dev/null; then
            log "  fixed mode on $FLEET_KEY (now 0640)"
        fi
    fi
    if [ "$(stat -c '%U:%G' "$FLEET_KEY" 2>/dev/null)" != "root:xcesp" ]; then
        if chown root:xcesp "$FLEET_KEY" 2>/dev/null; then
            log "  fixed ownership on $FLEET_KEY (now root:xcesp)"
        fi
    fi
    log "  fleet.key present (cross-machine secret portability available)"
else
    log "  fleet.key absent (machine-id mode — per-router secrets)"
fi

log "activation complete"
exit 0
