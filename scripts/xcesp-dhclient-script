#!/bin/sh
# xcesp-dhclient-script — minimal callback script for ISC dhclient.
#
# Path is hardcoded in RtrDhcpClientPObj.cpp:
#   dhclient ... -sf /usr/bin/xcesp-dhclient-script ...
#
# Scope:
#   This script manages the iface address AND the default gateway derived
#   from DHCP option 3 (new_routers).  It deliberately does NOT touch:
#     - /etc/resolv.conf      → xcesp manages DNS via RtrDnsProxy
#     - hostname / NIS / NTP  → out of scope for our use case
#   The default route is tagged `proto dhcp` so we can flush just that
#   one on lease teardown without disturbing operator-static defaults
#   the user added via `static-route 0.0.0.0/0`.
#   This keeps the script tiny and robust against distro-specific quirks
#   (the "dnfv" /sbin/dhclient-script on ARM64 Ubuntu uses vtysh and arping
#    and breaks silently when those aren't present — that's the bug this
#    file sidesteps).
#
# Capability chain:
#   Each binary in the chain (dhclient, /bin/sh, /sbin/ip) carries its own
#   file caps; ambient is irrelevant here.  As long as `/sbin/ip` has
#   cap_net_admin in its file caps (the distro default everywhere we ship),
#   `ip addr` calls below have the privilege they need.
#
# Invoked reasons (only those that need to do something are handled;
# everything else falls through as a no-op):

set -u

PATH=/usr/sbin:/usr/bin:/sbin:/bin
export PATH

# Use the xcesp-ip wrapper (cap_net_admin,cap_net_raw=ep, installed by
# xcesppkg) for the actual address manipulation.  ISC dhclient on
# Debian/Fedora drops the script to a non-root uid with no caps before
# invoking it; calling /usr/bin/ip directly here gets EPERM.  The wrapper
# re-execs /usr/bin/ip with ambient caps raised so `ip addr add` works.
# Fall back to plain `ip` if the wrapper isn't present (e.g. ARM64 dnfv
# where /usr/bin/ip already has the right file caps so we never needed it).
if [ -x /usr/lib/xcesp/xcesp-ip ]; then
    IP=/usr/lib/xcesp/xcesp-ip
else
    IP=ip
fi

netmask_to_prefix() {
    # POSIX bit-count of a dotted-quad netmask.  Falls back to /24 on garbage
    # input — better than nothing if dhclient passes something unexpected.
    nm="$1"
    bits=0
    OLDIFS=$IFS
    IFS=.
    # shellcheck disable=SC2086
    set -- $nm
    IFS=$OLDIFS
    for oct in "$@"; do
        case "$oct" in
            255) bits=$((bits + 8)) ;;
            254) bits=$((bits + 7)) ;;
            252) bits=$((bits + 6)) ;;
            248) bits=$((bits + 5)) ;;
            240) bits=$((bits + 4)) ;;
            224) bits=$((bits + 3)) ;;
            192) bits=$((bits + 2)) ;;
            128) bits=$((bits + 1)) ;;
            0)   ;;
            *) bits=24 ;;
        esac
    done
    printf "%d" "$bits"
}

install_v4() {
    new_ip="$1"
    new_nm="$2"
    new_bcast="${3:-}"
    new_lt="${4:-}"
    pfx=$(netmask_to_prefix "$new_nm")
    # Flush only dynamic v4 — static addresses added by RtrInterface keep
    # valid_lft=forever (no dynamic flag) and survive the flush.
    "$IP" -4 addr flush dev "$interface" scope global dynamic 2>/dev/null || true
    set -- "${new_ip}/${pfx}"
    if [ -n "$new_bcast" ]; then
        set -- "$@" broadcast "$new_bcast"
    fi
    if [ -n "$new_lt" ] && [ "$new_lt" != "infinite" ] && [ "$new_lt" -gt 0 ] 2>/dev/null; then
        set -- "$@" valid_lft "$new_lt" preferred_lft "$new_lt"
    fi
    "$IP" -4 addr add "$@" dev "$interface"
}

install_default_route_v4() {
    # Install default route from DHCP option 3 (Router).  new_routers is a
    # space-separated list; we use the first entry.  Tagged `proto dhcp`
    # so operator-static defaults (proto boot/static) remain untouched on
    # tear-down, and so a repeated BOUND replaces the entry idempotently
    # instead of accumulating duplicates.
    routers="${new_routers:-}"
    [ -z "$routers" ] && return 0
    # shellcheck disable=SC2086
    set -- $routers
    gw="$1"
    # Clear any prior dhcp-tagged default via this iface, then install fresh.
    "$IP" -4 route flush proto dhcp dev "$interface" 2>/dev/null || true
    "$IP" -4 route replace default via "$gw" dev "$interface" proto dhcp 2>/dev/null \
        || true
}

remove_v4() {
    "$IP" -4 addr  flush dev "$interface" scope global dynamic 2>/dev/null || true
    "$IP" -4 route flush dev "$interface" proto dhcp           2>/dev/null || true
}

# DHCPv6 install: dhclient -6 exports `new_ip6_address` plus
# `new_preferred_life` / `new_max_life`.  There is no subnet mask in v6
# DHCP — leased addresses are conventionally /128.  Per RFC 8415 the
# link prefix arrives via Router Advertisement (SLAAC), not DHCP; we
# leave RA-driven prefix routing untouched and only install the leased
# /128 here.  Existing dynamic v6 globals are flushed first so
# repeated BOUND6 callbacks don't accumulate.
install_v6() {
    new_ip="$1"
    pref="${2:-}"
    max="${3:-}"
    "$IP" -6 addr flush dev "$interface" scope global dynamic 2>/dev/null || true
    set -- "${new_ip}/128"
    if [ -n "$max" ] && [ "$max" != "infinite" ] && [ "$max" -gt 0 ] 2>/dev/null; then
        set -- "$@" valid_lft "$max"
    fi
    if [ -n "$pref" ] && [ "$pref" != "infinite" ] && [ "$pref" -gt 0 ] 2>/dev/null; then
        set -- "$@" preferred_lft "$pref"
    fi
    "$IP" -6 addr add "$@" dev "$interface"
}

remove_v6() {
    "$IP" -6 addr flush dev "$interface" scope global dynamic 2>/dev/null || true
}

case "${reason:-}" in
    MEDIUM)
        # Link-layer / media-type set.  We don't manage media; no-op.
        :
        ;;
    PREINIT|PREINIT6)
        # Bring iface up so dhclient can send DISCOVER / SOLICIT.
        # RtrInterface should already have done this, but it's cheap and
        # idempotent.
        "$IP" link set dev "$interface" up 2>/dev/null || true
        ;;
    ARPCHECK|ARPSEND)
        # The stock script runs `arping -D` here and returns non-zero on
        # collision, which makes dhclient send DHCPDECLINE.  In our isolated
        # per-netns world the offered IP can never collide with a host we
        # don't already know about, and the accumulating-secondary-address
        # failure mode we saw on Debian came from this exact step.  Skip it.
        exit 0
        ;;
    BOUND|RENEW|REBIND|REBOOT)
        if [ -n "${new_ip_address:-}" ] && [ -n "${new_subnet_mask:-}" ]; then
            install_v4 "$new_ip_address" "$new_subnet_mask" \
                       "${new_broadcast_address:-}" "${new_dhcp_lease_time:-}"
            install_default_route_v4
        fi
        ;;
    BOUND6|RENEW6|REBIND6)
        if [ -n "${new_ip6_address:-}" ]; then
            install_v6 "$new_ip6_address" \
                       "${new_preferred_life:-}" "${new_max_life:-}"
        fi
        ;;
    EXPIRE|FAIL|RELEASE|STOP|TIMEOUT)
        remove_v4
        ;;
    EXPIRE6|RELEASE6|STOP6|DEPREF6)
        remove_v6
        ;;
    *)
        # Anything else (NBI, etc.) — no-op.  Exiting 0 here is what dhclient
        # expects for "I handled it, carry on".
        :
        ;;
esac

exit 0
